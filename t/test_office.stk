## t/test_office.stk — round-trip assertions for the stryke `Office` package.
##
## Uses stryke's native test framework. Requires the cdylib installed
## (`s pkg install -g .`) so `use Office` dlopens libstryke_office.
## Every format is written then read back over a temp file — no external
## tools are invoked.

use Office

val $dir = $ENV{TMPDIR} // "/tmp"
val $tag = "stryke-office-stk-$$"

# ── cdylib reachable ────────────────────────────────────────────────
assert_ok Office::version(), "Office::version returns truthy (cdylib loaded)"

# ── spreadsheet: xlsx round-trip ────────────────────────────────────
val $xlsx = "$dir/$tag.xlsx"
Office::sheet_write($xlsx, [{ name => "Data", rows => [["name", "qty"], ["widget", 3]] }])
val $xs = Office::sheet_read($xlsx)
assert_eq $xs->[0]{rows}[0][0], "name", "xlsx: header cell round-trips"
assert_eq $xs->[0]{rows}[1][1], 3, "xlsx: numeric cell round-trips as number"
unlink $xlsx

# ── spreadsheet: ods round-trip ─────────────────────────────────────
val $ods = "$dir/$tag.ods"
Office::sheet_write($ods, [{ name => "S", rows => [["a", "b"], ["c", "d"]] }])
val $os = Office::sheet_read($ods)
assert_eq $os->[0]{rows}[1][1], "d", "ods: cell round-trips"
unlink $ods

# ── document: docx round-trip ───────────────────────────────────────
val $docx = "$dir/$tag.docx"
Office::doc_write($docx, [
    { kind => "heading", level => 1, text => "Title" },
    { kind => "para", text => "Hello world" },
])
val @dp = Office::doc_read($docx)
assert_ok scalar(grep { /Hello world/ } @dp), "docx: body paragraph round-trips"
unlink $docx

# ── document: odt round-trip ────────────────────────────────────────
val $odt = "$dir/$tag.odt"
Office::doc_write($odt, [{ kind => "para", text => "odt body line" }])
val @op = Office::doc_read($odt)
assert_ok scalar(grep { /odt body line/ } @op), "odt: paragraph round-trips"
unlink $odt

# ── presentation: pptx round-trip ───────────────────────────────────
val $pptx = "$dir/$tag.pptx"
Office::slides_write($pptx, [{ title => "Slide One", body => ["bullet a"] }])
val $ps = Office::slides_read($pptx)
assert_ok scalar(grep { /Slide One/ } @{ $ps->[0]{text} }), "pptx: slide title round-trips"
unlink $pptx

# ── presentation: odp round-trip ────────────────────────────────────
val $odp = "$dir/$tag.odp"
Office::slides_write($odp, [{ title => "Intro", body => ["point one"] }])
val $ops = Office::slides_read($odp)
assert_ok scalar(grep { /Intro/ } @{ $ops->[0]{text} }), "odp: slide text round-trips"
unlink $odp

# ── pdf round-trip ──────────────────────────────────────────────────
val $pdf = "$dir/$tag.pdf"
Office::pdf_write($pdf, ["First line", "Second line"])
val $pr = Office::pdf_read($pdf)
assert_ok ($pr->{text} =~ /First line/), "pdf: written text extracts back"
unlink $pdf

# ── image: new, draw, save, reopen, pixel ───────────────────────────
val $png = "$dir/$tag.png"
val $img = Office::img_new(64, 48, color => [255, 0, 0, 255])
Office::img_draw_rect($img->{handle}, 4, 4, 20, 10, [0, 0, 255, 255])
Office::img_save($img->{handle}, $png)
val $re = Office::img_open($png)
assert_eq $re->{width}, 64, "image: width round-trips"
val $px = Office::img_get_pixel($re->{handle}, 10, 8)
assert_eq $px->{b}, 255, "image: drawn blue pixel round-trips"
Office::img_close($img->{handle})
Office::img_close($re->{handle})
unlink $png

# ── image: resize + grayscale convert ───────────────────────────────
val $im2 = Office::img_new(100, 80, color => "#0a141e")
val $rz = Office::img_resize($im2->{handle}, 50, 40)
assert_eq $rz->{width}, 50, "image: resize to exact width"
val $gr = Office::img_convert($im2->{handle}, "L")
assert_eq $gr->{mode}, "L", "image: convert to grayscale"
Office::img_close($im2->{handle})

# ── pure helpers (no workbook — always run) ──────────────────────────
val $c = Office::parse_a1("B2")
assert_eq $c->{row},    1,   "parse_a1: 0-based row"
assert_eq $c->{col},    1,   "parse_a1: 0-based col"
assert_eq $c->{row_1},  2,   "parse_a1: 1-based row"
assert_eq $c->{letter}, "B", "parse_a1: column letter"
val $aa = Office::parse_a1("AA10")
assert_eq $aa->{col}, 26, "parse_a1: AA is column 26 (0-based)"

# offset_a1: relative-reference adjustment (formula fill/copy).
assert_eq Office::offset_a1("B2", 1, 2)->{cell},   "D3",  "offset_a1: B2 + (1,2) = D3"
assert_eq Office::offset_a1("D3", -1, -2)->{cell}, "B2",  "offset_a1: negative deltas move up/left"
assert_eq Office::offset_a1("Z1", 0, 1)->{cell},   "AA1", "offset_a1: column carry past Z"
assert_eq Office::offset_a1("c5")->{cell},         "C5",  "offset_a1: zero deltas normalize casing"
assert_dies fn { Office::offset_a1("A1", -1, 0) }, "offset_a1: rejects an offset above row 1"
# parse_a1_abs: Excel dollar absolute markers ('\$' escapes stryke interpolation).
val $abs = Office::parse_a1_abs("\$B\$2")
assert_eq $abs->{row}, 1,             "parse_a1_abs: row 0-based"
assert_ok $abs->{col_absolute},       "parse_a1_abs: absolute column marker"
assert_ok $abs->{row_absolute},       "parse_a1_abs: absolute row marker"
assert_eq $abs->{cell}, "\$B\$2",     "parse_a1_abs: normalized keeps both markers"
val $mix = Office::parse_a1_abs("A\$1")
assert_eq $mix->{col_absolute}, 0,    "parse_a1_abs: relative column"
assert_ok $mix->{row_absolute},       "parse_a1_abs: absolute row"
assert_eq Office::parse_a1_abs("aa10")->{cell}, "AA10", "parse_a1_abs: relative ref normalizes casing"
assert_dies fn { Office::parse_a1_abs("A1\$") }, "parse_a1_abs: rejects malformed reference"

# a1_abs_of: build $-marked reference from parts (inverse of parse_a1_abs).
assert_eq Office::a1_abs_of(1, 1, 1, 1), "\$B\$2", "a1_abs_of: both flags → fully absolute"
assert_eq Office::a1_abs_of(0, 0, 1),    "\$A1",  "a1_abs_of: absolute column only"
assert_eq Office::a1_abs_of(0, 0, undef, 1), "A\$1", "a1_abs_of: absolute row only"
assert_eq Office::a1_abs_of(9, 26),      "AA10", "a1_abs_of: no flags → plain ref"
# round-trips parse_a1_abs.
val $rt = Office::parse_a1_abs("\$B\$2")
assert_eq Office::a1_abs_of($rt->{row}, $rt->{col}, $rt->{col_absolute}, $rt->{row_absolute}), "\$B\$2", "a1_abs_of: round-trips parse_a1_abs"

assert_eq Office::a1_of(9, 26),       "AA10", "a1_of: inverse of parse_a1"
assert_eq Office::col_to_letter(26),  "AA",   "col_to_letter: 26 → AA"
assert_eq Office::letter_to_col("AA"), 26,    "letter_to_col: AA → 26"

val $rg = Office::parse_range("A1:C4")
assert_eq $rg->{rows}, 4, "parse_range: 4 rows"
assert_eq $rg->{cols}, 3, "parse_range: 3 cols"
assert_eq $rg->{end}{col}, 2, "parse_range: end col 0-based"

# range_of: inverse of parse_range, corners normalized.
assert_eq Office::range_of(0, 0, 3, 2)->{range}, "A1:C4", "range_of: corners → A1 range"
assert_eq Office::range_of(3, 2, 0, 0)->{range}, "A1:C4", "range_of: normalizes swapped corners"
assert_eq Office::range_of(0, 0, 0, 27)->{range}, "A1:AB1", "range_of: multi-letter column carry"
assert_eq Office::range_of(0, 0, 3, 2)->{rows}, 4, "range_of: row span"

# expand_range: A1 range → individual cell references, row-major.
val @cells = Office::expand_range("A1:B2")
assert_eq scalar(@cells), 4, "expand_range: 2x2 → 4 cells"
assert_eq join(",", @cells), "A1,B1,A2,B2", "expand_range: row-major order"
assert_eq join(",", Office::expand_range("C3:C3")), "C3", "expand_range: single cell"
assert_dies fn { Office::expand_range("A1:Z100", limit => 10) }, "expand_range: limit guard rejects oversized range"

# bounding_range: smallest A1 range containing a list of cells.
assert_eq Office::bounding_range("B2", "D1", "C5", "A3")->{range}, "A1:D5", "bounding_range: envelope of scattered cells"
assert_eq Office::bounding_range("C3")->{range}, "C3:C3", "bounding_range: single cell bounds to itself"
assert_eq Office::bounding_range("Z1", "AA2")->{range}, "Z1:AA2", "bounding_range: multi-letter column"
assert_eq Office::bounding_range(Office::expand_range("B2:D4"))->{range}, "B2:D4", "bounding_range: round-trips expand_range"
assert_dies fn { Office::bounding_range() }, "bounding_range: rejects an empty cell list"

# range_intersection: overlapping rectangle of two A1 ranges.
assert_eq Office::range_intersection("A1:C3", "B2:D4")->{range}, "B2:C3", "range_intersection: overlap box"
assert_eq Office::range_intersection("A1:Z100", "C3:E5")->{range}, "C3:E5", "range_intersection: inner range when nested"
assert_eq Office::range_intersection("A1:B2", "D1:E2")->{intersect}, 0, "range_intersection: disjoint columns → no overlap"
assert_eq Office::range_intersection("A1:C3", "C1:E3")->{cols}, 1, "range_intersection: shared edge column"
assert_dies fn { Office::range_intersection("A1", "B2:C3") }, "range_intersection: rejects a malformed range"

# range_contains: does a range fully contain a cell or sub-range?
assert_eq Office::range_contains("A1:C3", cell => "B2")->{contains}, 1, "range_contains: interior cell"
assert_eq Office::range_contains("A1:C3", cell => "D4")->{contains}, 0, "range_contains: cell outside"
assert_eq Office::range_contains("A1:Z100", inner => "C3:E5")->{contains}, 1, "range_contains: nested sub-range"
assert_eq Office::range_contains("A1:C3", inner => "B2:D4")->{contains}, 0, "range_contains: sub-range pokes outside"
assert_dies fn { Office::range_contains("A1:C3") }, "range_contains: requires a cell or inner range"

# range_union: smallest A1 range enclosing both (bounding box).
assert_eq Office::range_union("A1:B2", "D5:E6")->{range}, "A1:E6", "range_union: disjoint → bounding box"
assert_eq Office::range_union("A1:C3", "B2:D4")->{range}, "A1:D4", "range_union: overlapping → enclosing box"
assert_eq Office::range_union("A1:Z100", "C3:E5")->{range}, "A1:Z100", "range_union: nested → the outer range"
val $u = Office::range_union("B2:C3", "B2:C3")
assert_eq $u->{range}, "B2:C3", "range_union: identical ranges → itself"
assert_eq $u->{rows}, 2, "range_union: rows of the bounding box"
assert_eq $u->{cols}, 2, "range_union: cols of the bounding box"
# Union always contains both inputs (cross-check with range_contains).
assert_eq Office::range_contains(Office::range_union("A1:B2", "D5:E6")->{range}, inner => "A1:B2")->{contains}, 1, "range_union: result contains the first input"
assert_dies fn { Office::range_union("A1", "B2:C3") }, "range_union: rejects a malformed range"

# range_offset: shift a whole range, preserving its size (range analog of offset_a1).
assert_eq Office::range_offset("B2:C4", 1, 2)->{range}, "D3:E5", "range_offset: B2:C4 + (1,2) = D3:E5"
val $ro = Office::range_offset("B2:C4", 1, 2)
assert_eq $ro->{rows}, 3, "range_offset: preserves row count"
assert_eq $ro->{cols}, 2, "range_offset: preserves col count"
assert_eq Office::range_offset("D3:E5", -1, -2)->{range}, "B2:C4", "range_offset: negative deltas invert"
assert_eq Office::range_offset("Z1:Z2", 0, 1)->{range},   "AA1:AA2", "range_offset: column carry past Z"
assert_eq Office::range_offset("C5:D6")->{range},         "C5:D6", "range_offset: zero deltas normalize casing"
assert_dies fn { Office::range_offset("A1:B2", -1, 0) }, "range_offset: rejects an offset above row 1"
assert_dies fn { Office::range_offset("A1:B2", 0, -1) }, "range_offset: rejects an offset left of column A"

# range_to_absolute: lock both corners with $ (range analog of a1_abs_of).
assert_eq Office::range_to_absolute("A1:B2")->{range}, "\$A\$1:\$B\$2", "range_to_absolute: A1:B2 → \$A\$1:\$B\$2"
val $abs = Office::range_to_absolute("B2:C4")
assert_eq $abs->{start}, "\$B\$2", "range_to_absolute: start corner locked"
assert_eq $abs->{end},   "\$C\$4", "range_to_absolute: end corner locked"
assert_eq $abs->{rows},  3,         "range_to_absolute: preserves row count"
assert_eq Office::range_to_absolute("C4:B2")->{range}, "\$B\$2:\$C\$4", "range_to_absolute: corners normalized"

# range_to_relative: inverse of range_to_absolute (strip the $ locks).
assert_eq Office::range_to_relative("\$A\$1:\$B\$2")->{range}, "A1:B2", "range_to_relative: \$A\$1:\$B\$2 → A1:B2"
assert_eq Office::range_to_relative(Office::range_to_absolute("B2:C4")->{range})->{range}, "B2:C4", "range_to_relative: round-trips range_to_absolute"
assert_eq Office::range_to_relative("\$C\$4:\$B\$2")->{range}, "B2:C4", "range_to_relative: corners normalized"
assert_eq Office::range_to_relative("A1:B2")->{range}, "A1:B2", "range_to_relative: already-relative input is unchanged"

test_run
