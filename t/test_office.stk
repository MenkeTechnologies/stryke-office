## t/test_office.stk — round-trip assertions for the stryke `Office` package.
##
## Uses stryke's native test framework. Requires the cdylib installed
## (`s pkg install -g .`) so `use Office` dlopens libstryke_office.
## Every format is written then read back over a temp file — no external
## tools are invoked.

use Office

val $dir = $ENV{TMPDIR} // "/tmp"
val $tag = "stryke-office-stk-$$"

# ── cdylib reachable ────────────────────────────────────────────────
assert_ok Office::version(), "Office::version returns truthy (cdylib loaded)"

# ── spreadsheet: xlsx round-trip ────────────────────────────────────
val $xlsx = "$dir/$tag.xlsx"
Office::sheet_write($xlsx, [{ name => "Data", rows => [["name", "qty"], ["widget", 3]] }])
val $xs = Office::sheet_read($xlsx)
assert_eq $xs->[0]{rows}[0][0], "name", "xlsx: header cell round-trips"
assert_eq $xs->[0]{rows}[1][1], 3, "xlsx: numeric cell round-trips as number"
unlink $xlsx

# ── spreadsheet: ods round-trip ─────────────────────────────────────
val $ods = "$dir/$tag.ods"
Office::sheet_write($ods, [{ name => "S", rows => [["a", "b"], ["c", "d"]] }])
val $os = Office::sheet_read($ods)
assert_eq $os->[0]{rows}[1][1], "d", "ods: cell round-trips"
unlink $ods

# ── document: docx round-trip ───────────────────────────────────────
val $docx = "$dir/$tag.docx"
Office::doc_write($docx, [
    { kind => "heading", level => 1, text => "Title" },
    { kind => "para", text => "Hello world" },
])
val @dp = Office::doc_read($docx)
assert_ok scalar(grep { /Hello world/ } @dp), "docx: body paragraph round-trips"
unlink $docx

# ── document: odt round-trip ────────────────────────────────────────
val $odt = "$dir/$tag.odt"
Office::doc_write($odt, [{ kind => "para", text => "odt body line" }])
val @op = Office::doc_read($odt)
assert_ok scalar(grep { /odt body line/ } @op), "odt: paragraph round-trips"
unlink $odt

# ── presentation: pptx round-trip ───────────────────────────────────
val $pptx = "$dir/$tag.pptx"
Office::slides_write($pptx, [{ title => "Slide One", body => ["bullet a"] }])
val $ps = Office::slides_read($pptx)
assert_ok scalar(grep { /Slide One/ } @{ $ps->[0]{text} }), "pptx: slide title round-trips"
unlink $pptx

# ── presentation: odp round-trip ────────────────────────────────────
val $odp = "$dir/$tag.odp"
Office::slides_write($odp, [{ title => "Intro", body => ["point one"] }])
val $ops = Office::slides_read($odp)
assert_ok scalar(grep { /Intro/ } @{ $ops->[0]{text} }), "odp: slide text round-trips"
unlink $odp

# ── pdf round-trip ──────────────────────────────────────────────────
val $pdf = "$dir/$tag.pdf"
Office::pdf_write($pdf, ["First line", "Second line"])
val $pr = Office::pdf_read($pdf)
assert_ok ($pr->{text} =~ /First line/), "pdf: written text extracts back"
unlink $pdf

# ── image: new, draw, save, reopen, pixel ───────────────────────────
val $png = "$dir/$tag.png"
val $img = Office::img_new(64, 48, color => [255, 0, 0, 255])
Office::img_draw_rect($img->{handle}, 4, 4, 20, 10, [0, 0, 255, 255])
Office::img_save($img->{handle}, $png)
val $re = Office::img_open($png)
assert_eq $re->{width}, 64, "image: width round-trips"
val $px = Office::img_get_pixel($re->{handle}, 10, 8)
assert_eq $px->{b}, 255, "image: drawn blue pixel round-trips"
Office::img_close($img->{handle})
Office::img_close($re->{handle})
unlink $png

# ── image: resize + grayscale convert ───────────────────────────────
val $im2 = Office::img_new(100, 80, color => "#0a141e")
val $rz = Office::img_resize($im2->{handle}, 50, 40)
assert_eq $rz->{width}, 50, "image: resize to exact width"
val $gr = Office::img_convert($im2->{handle}, "L")
assert_eq $gr->{mode}, "L", "image: convert to grayscale"
Office::img_close($im2->{handle})

# ── pure helpers (no workbook — always run) ──────────────────────────
val $c = Office::parse_a1("B2")
assert_eq $c->{row},    1,   "parse_a1: 0-based row"
assert_eq $c->{col},    1,   "parse_a1: 0-based col"
assert_eq $c->{row_1},  2,   "parse_a1: 1-based row"
assert_eq $c->{letter}, "B", "parse_a1: column letter"
val $aa = Office::parse_a1("AA10")
assert_eq $aa->{col}, 26, "parse_a1: AA is column 26 (0-based)"

assert_eq Office::a1_of(9, 26),       "AA10", "a1_of: inverse of parse_a1"
assert_eq Office::col_to_letter(26),  "AA",   "col_to_letter: 26 → AA"
assert_eq Office::letter_to_col("AA"), 26,    "letter_to_col: AA → 26"

val $rg = Office::parse_range("A1:C4")
assert_eq $rg->{rows}, 4, "parse_range: 4 rows"
assert_eq $rg->{cols}, 3, "parse_range: 3 cols"
assert_eq $rg->{end}{col}, 2, "parse_range: end col 0-based"

test_run
