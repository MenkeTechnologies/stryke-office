## t/test_office_wrappers.stk — runtime round-trips for wrappers that the
## FFI-level Rust suite does not exercise: the hashref-argument wrappers
## (replace_text / text_replace / meta_write / pdf_set_outline) and the
## conversion + analytics functions added on top of the original surface.
##
## These call the real `Office::*` stryke wrappers, so they catch wrapper-layer
## bugs (e.g. assigning a hashref literal to a `%` hash) that direct FFI tests
## miss. Requires the cdylib installed (`s pkg install -g .`).

use Office

val $dir = $ENV{TMPDIR} // "/tmp"
val $tag = "stryke-office-wrap-$$"

# ── replace_text: hashref { find => replacement } across a docx ──────
val $docx = "$dir/$tag.docx"
Office::doc_write($docx, [{ kind => "para", text => "Hello NAME" }])
Office::replace_text($docx, { NAME => "World" })
val @rp = Office::doc_read($docx)
assert_ok scalar(grep { /Hello World/ } @rp), "replace_text: placeholder replaced"
unlink $docx

# ── text_replace: hashref over a plain-text csv ─────────────────────
val $csv = "$dir/$tag.csv"
Office::sheet_write($csv, [{ name => "S", rows => [["a", "b"], ["foo", "bar"]] }])
Office::text_replace($csv, { foo => "baz" })
val $cs = Office::sheet_read($csv)
assert_eq $cs->[0]{rows}[1][0], "baz", "text_replace: csv cell replaced"
unlink $csv

# ── meta_write / meta_read: hashref props ───────────────────────────
val $mx = "$dir/$tag-meta.docx"
Office::doc_write($mx, [{ kind => "para", text => "body" }])
Office::meta_write($mx, { title => "My Title", author => "Jane" })
val $meta = Office::meta_read($mx)
assert_eq $meta->{title}, "My Title", "meta_write/read: title round-trips"
unlink $mx

# ── pdf_set_outline / pdf_outline: arrayref of bookmark nodes ───────
val $pdf = "$dir/$tag.pdf"
Office::pdf_write($pdf, ["Page one"])
Office::pdf_set_outline($pdf, [{ title => "Top", page => 1 }])
val $ol = Office::pdf_outline($pdf)
assert_eq $ol->{count}, 1, "pdf_set_outline: one bookmark"
assert_eq $ol->{outline}[0]{title}, "Top", "pdf_set_outline: title round-trips"
unlink $pdf

# ── spreadsheet <-> markdown round-trip ─────────────────────────────
val $xl = "$dir/$tag-2.xlsx"
Office::sheet_write($xl, [{ name => "S", rows => [["Item", "Count"], ["apples", 5]] }])
val $md = Office::sheet_to_md($xl)
assert_ok ($md->{markdown} =~ /\| Item \| Count \|/), "sheet_to_md: header row"

val $back = "$dir/$tag-md.xlsx"
Office::md_to_sheet($back, markdown => "| A | B |\n| --- | --- |\n| 1 | 2 |")
val $ms = Office::sheet_read($back)
assert_eq $ms->[0]{rows}[0][0], "A", "md_to_sheet: header parsed"
unlink $back

# ── spreadsheet -> html ─────────────────────────────────────────────
val $html = Office::sheet_to_html($xl, title => "Report")
assert_ok ($html->{html} =~ /<th>Item<\/th>/), "sheet_to_html: header cell"

# ── analytics: describe + freq ──────────────────────────────────────
val $desc = Office::sheet_describe($xl)
assert_eq $desc->{columns}[0]{mean}, 5, "sheet_describe: numeric mean"

val $fr = Office::sheet_freq($xl, "Item")
assert_eq $fr->{total}, 1, "sheet_freq: counted rows"
unlink $xl

# ── deck -> markdown + html ─────────────────────────────────────────
val $pptx = "$dir/$tag.pptx"
Office::slides_write($pptx, [{ title => "Intro", body => ["a", "b"] }])
val $smd = Office::slides_to_md($pptx)
assert_ok ($smd->{markdown} =~ /## Intro/), "slides_to_md: title heading"
val $shtml = Office::slides_to_html($pptx)
assert_ok ($shtml->{html} =~ /<h2>Intro<\/h2>/), "slides_to_html: title section"
unlink $pptx

# ── pdf text statistics ─────────────────────────────────────────────
val $ps = "$dir/$tag-s.pdf"
Office::pdf_write($ps, ["alpha beta", "gamma"])
val $stats = Office::pdf_stats($ps)
assert_eq $stats->{pages}, 1, "pdf_stats: page count"
assert_ok ($stats->{words} >= 3), "pdf_stats: word count"
unlink $ps

# ── sheet_to_ndjson: JSON Lines export ──────────────────────────────
val $nx = "$dir/$tag-nd.xlsx"
Office::sheet_write($nx, [{ name => "D", rows => [["name", "qty"], ["a", 1], ["b", 2]] }])
val $no = "$dir/$tag-nd.jsonl"
val $nr = Office::sheet_to_ndjson($nx, $no)
assert_eq $nr->{count}, 2, "sheet_to_ndjson: record count"
# import the JSON Lines back into a sheet (inverse)
val $nb = "$dir/$tag-nd-back.xlsx"
val $nir = Office::ndjson_to_sheet($nb, input => $no)
assert_eq $nir->{rows}, 2, "ndjson_to_sheet: rows imported"
val $nbr = Office::sheet_read($nb)
assert_eq $nbr->[0]{rows}[1][0], "a", "ndjson_to_sheet: value round-trips"
unlink $nx
unlink $no
unlink $nb

# ── sheet_transform: per-column op ──────────────────────────────────
val $tx = "$dir/$tag-xform.xlsx"
Office::sheet_write($tx, [{ name => "D", rows => [["name"], ["  hi "], ["YO"]] }])
val $txo = "$dir/$tag-xform-out.xlsx"
Office::sheet_transform($tx, "name", "trim", $txo)
val $txr = Office::sheet_read($txo)
assert_eq $txr->[0]{rows}[1][0], "hi", "sheet_transform: trim in place"
unlink $tx
unlink $txo

# ── sheet_sample: reproducible row sampling ─────────────────────────
val $sx = "$dir/$tag-samp.xlsx"
Office::sheet_write($sx, [{ name => "D", rows => [["h"], [1], [2], [3], [4], [5]] }])
val $so = "$dir/$tag-samp-out.xlsx"
val $sr = Office::sheet_sample($sx, $so, n => 2, seed => 7)
assert_eq $sr->{rows}, 2, "sheet_sample: sampled count"
val $srd = Office::sheet_read($so)
assert_eq $srd->[0]{rows}[0][0], "h", "sheet_sample: header kept"
unlink $sx
unlink $so

# ── xml entity survival across text extraction (regression) ─────────
val $ent = "$dir/$tag-ent.pptx"
Office::slides_write($ent, [{ title => "R&D", body => ["a & b"] }])
val $entr = Office::slides_read($ent)
assert_ok scalar(grep { /R&D/ } @{ $entr->[0]{text} }), "entity: ampersand survives slide read"
unlink $ent

# ── slides_add_image: embed a picture on a slide ────────────────────
val $idk = "$dir/$tag-imgdeck.pptx"
Office::slides_write($idk, [{ title => "Cover", body => ["x"] }])
val $logo = "$dir/$tag-logo.png"
val $im = Office::img_new(16, 8, color => [10, 20, 30, 255])
Office::img_save($im->{handle}, $logo)
Office::img_close($im->{handle})
Office::slides_add_image($idk, $logo)
val $ex = Office::extract_images($idk)
assert_eq $ex->{count}, 1, "slides_add_image: image embedded"
assert_eq $ex->{images}[0]{width}, 16, "slides_add_image: native width"
unlink $idk
unlink $logo

# ── document -> pdf ─────────────────────────────────────────────────
val $d2p = "$dir/$tag-d2p.docx"
Office::doc_write($d2p, [
    { kind => "heading", level => 1, text => "Chapter" },
    { kind => "para", text => "intro body" },
])
val $d2ppdf = "$dir/$tag-d2p.pdf"
Office::doc_to_pdf($d2p, $d2ppdf)
val $d2pr = Office::pdf_read($d2ppdf)
assert_ok ($d2pr->{text} =~ /Chapter/), "doc_to_pdf: heading renders into pdf"
unlink $d2p
unlink $d2ppdf

test_run
