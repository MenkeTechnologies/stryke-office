## t/test_stryke_office_surface.stk — wrapper-completeness pin.
##
## Asserts every public `fn Office::name` declared in lib/Office.stk is
## reachable via `use` at runtime. Permission-free — no files, no daemon.
## Private helpers (`_` prefix) are implementation detail, not asserted.

use Office

assert_ok exists &Office::version, "Office::version exists"
assert_ok exists &Office::sheet_read, "Office::sheet_read exists"
assert_ok exists &Office::sheet_write, "Office::sheet_write exists"
assert_ok exists &Office::doc_read, "Office::doc_read exists"
assert_ok exists &Office::doc_write, "Office::doc_write exists"
assert_ok exists &Office::slides_read, "Office::slides_read exists"
assert_ok exists &Office::slides_write, "Office::slides_write exists"
assert_ok exists &Office::pdf_read, "Office::pdf_read exists"
assert_ok exists &Office::pdf_write, "Office::pdf_write exists"

# image surface
assert_ok exists &Office::img_open, "Office::img_open exists"
assert_ok exists &Office::img_new, "Office::img_new exists"
assert_ok exists &Office::img_save, "Office::img_save exists"
assert_ok exists &Office::img_info, "Office::img_info exists"
assert_ok exists &Office::img_resize, "Office::img_resize exists"
assert_ok exists &Office::img_thumbnail, "Office::img_thumbnail exists"
assert_ok exists &Office::img_crop, "Office::img_crop exists"
assert_ok exists &Office::img_rotate, "Office::img_rotate exists"
assert_ok exists &Office::img_flip, "Office::img_flip exists"
assert_ok exists &Office::img_convert, "Office::img_convert exists"
assert_ok exists &Office::img_paste, "Office::img_paste exists"
assert_ok exists &Office::img_get_pixel, "Office::img_get_pixel exists"
assert_ok exists &Office::img_put_pixel, "Office::img_put_pixel exists"
assert_ok exists &Office::img_draw_rect, "Office::img_draw_rect exists"
assert_ok exists &Office::img_draw_line, "Office::img_draw_line exists"
assert_ok exists &Office::img_draw_circle, "Office::img_draw_circle exists"
assert_ok exists &Office::img_draw_text, "Office::img_draw_text exists"
assert_ok exists &Office::img_close, "Office::img_close exists"

# image filters
assert_ok exists &Office::img_blur, "Office::img_blur exists"
assert_ok exists &Office::img_sharpen, "Office::img_sharpen exists"
assert_ok exists &Office::img_brighten, "Office::img_brighten exists"
assert_ok exists &Office::img_contrast, "Office::img_contrast exists"
assert_ok exists &Office::img_huerotate, "Office::img_huerotate exists"
assert_ok exists &Office::img_invert, "Office::img_invert exists"
assert_ok exists &Office::img_grayscale, "Office::img_grayscale exists"
assert_ok exists &Office::img_gamma, "Office::img_gamma exists"
assert_ok exists &Office::img_threshold, "Office::img_threshold exists"
assert_ok exists &Office::img_posterize, "Office::img_posterize exists"
assert_ok exists &Office::img_sepia, "Office::img_sepia exists"
assert_ok exists &Office::img_tint, "Office::img_tint exists"

# charting
assert_ok exists &Office::chart_render, "Office::chart_render exists"
assert_ok exists &Office::chart_svg, "Office::chart_svg exists"
assert_ok exists &Office::chart_save, "Office::chart_save exists"

# barcodes
assert_ok exists &Office::barcode_qr, "Office::barcode_qr exists"
assert_ok exists &Office::barcode_1d, "Office::barcode_1d exists"

# metadata
assert_ok exists &Office::meta_read, "Office::meta_read exists"
assert_ok exists &Office::meta_write, "Office::meta_write exists"

# media extraction
assert_ok exists &Office::extract_images, "Office::extract_images exists"

# text replace / templating
assert_ok exists &Office::replace_text, "Office::replace_text exists"

# pdf forms
assert_ok exists &Office::pdf_form_fields, "Office::pdf_form_fields exists"
assert_ok exists &Office::pdf_fill_form, "Office::pdf_fill_form exists"

# pdf outline
assert_ok exists &Office::pdf_outline, "Office::pdf_outline exists"
assert_ok exists &Office::pdf_set_outline, "Office::pdf_set_outline exists"

# A1 notation pure helpers
assert_ok exists &Office::parse_a1, "Office::parse_a1 exists"
assert_ok exists &Office::parse_a1_abs, "Office::parse_a1_abs exists"
assert_ok exists &Office::a1_of, "Office::a1_of exists"
assert_ok exists &Office::offset_a1, "Office::offset_a1 exists"
assert_ok exists &Office::a1_abs_of, "Office::a1_abs_of exists"
assert_ok exists &Office::col_to_letter, "Office::col_to_letter exists"
assert_ok exists &Office::letter_to_col, "Office::letter_to_col exists"
assert_ok exists &Office::parse_range, "Office::parse_range exists"
assert_ok exists &Office::range_of, "Office::range_of exists"
assert_ok exists &Office::expand_range, "Office::expand_range exists"
assert_ok exists &Office::bounding_range, "Office::bounding_range exists"
assert_ok exists &Office::range_intersection, "Office::range_intersection exists"

test_run
