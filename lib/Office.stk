# ── charts (data -> image handle -> any format) ─────────────────────
#
# Render a chart to an image handle, then img_save it in whatever format
# you want (png/jpeg/gif/bmp/webp/tiff) or process it further. Fully
# self-contained — no plotters, no system fonts, no external binaries.

## Render a chart to a raster image handle. $type is one of:
##   bar | column | stacked | line | area | stacked_area | step | combo |
##   scatter | bubble | pie | donut | radar | histogram | sankey | waterfall |
##   ohlc | candlestick | boxplot | funnel | gauge | heatmap | treemap |
##   polar | bullet | pareto | lollipop | dot | gantt | sunburst |
##   range | range_column | percent_stacked | streamgraph | waffle | slope |
##   marimekko | radial_bar | calendar | parallel | hexbin
## $series: arrayref of { name, data => [n, ...], color?, kind? }.
##   bullet series => { name, value, target, ranges => [r1,r2,...] };
##   gantt series => { name, start, end, color? };
##   range/range_column => data => [[low,high],...];
##   sunburst => rings => [[..],[..]] innermost first (no series needed);
##   calendar => values => [v,...] laid out 7 rows x N cols (no series needed);
##   parallel => each series is one row of per-dimension values (cats = axes);
##   hexbin => scatter data => [[x,y],...] binned into hex cells;
##   scatter accepts trendline => 1 to overlay a least-squares line.
## Cross-cutting opts: markers => 1 (line family), reference_lines =>
##   [{ y, color? }] (horizontal threshold lines), smooth => 1 (spline lines),
##   palette => ["#..."] (custom color cycle), background => "#..." (canvas),
##   log_y => 1 (logarithmic Y when all-positive), per-series errors => [e,...]
##   (error-bar whiskers), annotations => [{ x (data index), y, text, color? }].
##   scatter data => [[x, y], ...]; bubble => [[x, y, size], ...];
##   ohlc/candlestick => [[open, high, low, close], ...];
##   boxplot data => raw numbers (min/q1/median/q3/max computed);
##   combo series can set kind => "line" to overlay a line on the bars;
##   pie/funnel use the first series' data as slices/bands.
## opts: title, width (800), height (600), categories => [labels],
##   legend => 0 to suppress, labels => 1 for data labels, x_label, y_label,
##   bins (histogram), value+max (gauge), matrix => [[..],..] (heatmap),
##   nodes+links (sankey). Returns { handle, width, height, type } — pass the
## handle to Office::img_save (any raster format) or any img_* op.
fn Office::chart_render ($type, $series, %opts) {
    var %r = %opts
    $r{type} = $type
    $r{series} = $series
    Office::_decode("chart_render", office__chart_render(to_json(\%r)))
}

## Render a chart straight from a spreadsheet's columns and save it. $path is the
## spreadsheet, $output the chart file (.svg/.pdf/.png/... sets the format).
## opts: type (bar/line/...), sheet, header => 0, categories => column for x
## labels, series => arrayref of value columns (default: all numeric columns),
## plus chart options (title, width, height, smooth, ...). Returns the chart_save
## result.
fn Office::chart_from_sheet ($path, $output, %opts) {
    var %r = %opts
    $r{path} = $path
    $r{output} = $output
    Office::_decode("chart_from_sheet", office__chart_from_sheet(to_json(\%r)))
}

## Render a chart to a vector SVG string (returns the markup), or write it
## to %opts{path} if given. Same spec keys as chart_render.
fn Office::chart_svg ($type, $series, %opts) {
    var %r = %opts
    $r{type} = $type
    $r{series} = $series
    val $o = Office::_decode("chart_svg", office__chart_svg(to_json(\%r)))
    exists $o->{svg} ? $o->{svg} : $o
}

## Render many chart specs and tile them into one dashboard image. $charts is
## an arrayref of full chart specs (each as for chart_render). opts: cols,
## cell_width (400), cell_height (300), gap (10), background, path (save the
## grid straight to any raster extension or .pdf). Returns { handle, width,
## height, charts } — or { ok, path, charts } when path is given.
fn Office::chart_grid ($charts, %opts) {
    var %r = %opts
    $r{charts} = $charts
    Office::_decode("chart_grid", office__chart_grid(to_json(\%r)))
}

## Render a chart straight to a file, format chosen by $path extension:
## .svg (vector), .pdf (chart embedded in a PDF), or any raster extension
## (.png/.jpg/.tif/.bmp/.webp/.gif). Sankey takes nodes/links instead of
## series. Spec opts: title, width, height, categories, bins, nodes, links.
fn Office::chart_save ($type, $path, %opts) {
    var %r = %opts
    $r{type} = $type
    $r{path} = $path
    Office::_decode("chart_save", office__chart_save(to_json(\%r)))
}

## Generate a QR code -> image handle. opts: ec (L/M/Q/H, default M),
## scale (px/module, 6), quiet (modules, 4), fg, bg. Returns
## { handle, width, height, modules }. Save/embed via the image surface.
fn Office::barcode_qr ($data, %opts) {
    var %r = %opts
    $r{data} = $data
    Office::_decode("barcode_qr", office__barcode_qr(to_json(\%r)))
}

## Generate a 1D barcode -> image handle. $symbology is one of code128,
## code39, code93, code11, codabar, ean13, ean8, upca, itf, std2of5.
## opts: scale (px/bar, 2), height (px, 80), quiet (px), fg, bg, set
## (Code128 A/B/C). Returns { handle, width, height, symbology, bars }.
fn Office::barcode_1d ($symbology, $data, %opts) {
    var %r = %opts
    $r{symbology} = $symbology
    $r{data} = $data
    Office::_decode("barcode_1d", office__barcode_1d(to_json(\%r)))
}

## Generate a barcode straight to an image file (format by extension). $data is
## the payload. opts: kind => "qr" (default) | "1d", plus generator options
## (ec/scale/quiet for qr; symbology/scale/height for 1d; fg/bg). Returns
## { ok, path, kind, width, height }.
fn Office::barcode_save ($data, $output, %opts) {
    var %r = %opts
    $r{data} = $data
    $r{output} = $output
    Office::_decode("barcode_save", office__barcode_save(to_json(\%r)))
}

## Batch-generate one barcode/QR per value of $column into $dir (label sheets).
## opts: kind (qr|1d), symbology, ext (default png), prefix, plus barcode style
## opts (scale/ec/fg/bg/height), sheet, header. Returns { count, files }.
fn Office::barcode_sheet ($path, $column, $dir, %opts) {
    var %r = %opts
    $r{path} = $path
    $r{column} = $column
    $r{dir} = $dir
    Office::_decode("barcode_sheet", office__barcode_sheet(to_json(\%r)))
}

# ── pure helpers (no workbook): A1 / column math ──────────────────────

## Parse an A1 cell reference into a hashref { cell, row, col, row_1, col_1,
## letter } (row/col are 0-based; row_1/col_1 are 1-based).
fn Office::parse_a1 ($cell) {
    Office::_decode("parse_a1", office__parse_a1(to_json({ cell => $cell })))
}

## Parse an A1 reference with Excel $ absolute markers ($A$1, A$1, $A1, A1) into
## a hashref { cell, row, col, row_1, col_1, letter, col_absolute, row_absolute }.
## cell is normalized with its $ markers preserved. Unlike parse_a1 (relative-only).
fn Office::parse_a1_abs ($cell) {
    Office::_decode("parse_a1_abs", office__parse_a1_abs(to_json({ cell => $cell })))
}

## Build an A1 cell reference from 0-based $row and $col. Inverse of parse_a1.
fn Office::a1_of ($row, $col) {
    Office::_decode("a1_of", office__a1_of(to_json({ row => $row, col => $col })))->{cell}
}

## Shift A1 cell $cell by $row_delta rows and $col_delta cols — the relative-
## reference adjustment a spreadsheet applies on formula fill/copy. offset_a1
## ("B2", 1, 2) → { cell => "D3", … }. Deltas may be negative; an offset past
## row 1 / column A dies. Returns { cell, row, col, row_1, col_1, letter }.
fn Office::offset_a1 ($cell, $row_delta = 0, $col_delta = 0) {
    Office::_decode("offset_a1", office__offset_a1(to_json({ cell => $cell, row_delta => $row_delta, col_delta => $col_delta })))
}

## Build an A1 reference with Excel $ absolute markers from 0-based $row/$col and
## $col_abs/$row_abs flags — inverse of parse_a1_abs. With both true → $A$1; both
## false → the plain A1. Returns the cell string.
fn Office::a1_abs_of ($row, $col, $col_abs = undef, $row_abs = undef) {
    Office::_decode("a1_abs_of",
        office__a1_abs_of(to_json({ row => $row, col => $col, col_absolute => $col_abs, row_absolute => $row_abs })))->{cell}
}

## 0-based column index → column letters (0 → "A", 26 → "AA").
fn Office::col_to_letter ($col) {
    Office::_decode("col_to_letter", office__col_to_letter(to_json({ col => $col })))->{letter}
}

## Column letters → 0-based column index ("A" → 0, "AA" → 26).
fn Office::letter_to_col ($letter) {
    Office::_decode("letter_to_col", office__letter_to_col(to_json({ letter => $letter })))->{col}
}

## Parse an A1 range "A1:C4" into { start, end, rows, cols } (0-based row/col).
fn Office::parse_range ($range) {
    Office::_decode("parse_range", office__parse_range(to_json({ range => $range })))
}

## Build an A1 range "A1:C4" from 0-based corner indices. Corners are
## normalized to top-left:bottom-right regardless of order. Returns a hashref
## { range, start, end, rows, cols }. Inverse of parse_range.
fn Office::range_of ($start_row, $start_col, $end_row, $end_col) {
    Office::_decode("range_of", office__range_of(to_json({
        start_row => $start_row, start_col => $start_col,
        end_row   => $end_row,   end_col   => $end_col,
    })))
}

## Expand an A1 range "A1:B2" into its individual cell references in row-major
## order → ("A1", "B1", "A2", "B2"). %opts: limit (default 100000) caps the cell
## count. Returns the list of cell strings.
fn Office::expand_range ($range, %opts) {
    var %req = (range => $range)
    $req{limit} = $opts{limit} if defined $opts{limit}
    @{ Office::_decode("expand_range", office__expand_range(to_json(\%req)))->{cells} }
}

## Smallest A1 range that contains every cell in @cells — the selection bounding
## box. Returns a hashref { range, start, end, rows, cols }.
fn Office::bounding_range (@cells) {
    Office::_decode("bounding_range", office__bounding_range(to_json({ cells => \@cells })))
}

## Overlapping rectangle of two A1 ranges (the spreadsheet intersection
## operator). Returns { intersect => 1, range, start, end, rows, cols } when
## they overlap, or { intersect => 0, range => undef } when disjoint.
fn Office::range_intersection ($a, $b) {
    Office::_decode("range_intersection", office__range_intersection(to_json({ a => $a, b => $b })))
}

## Whether an A1 $range fully contains a target — pass %opts cell => "B2" for a
## single cell or inner => "A1:B2" for a sub-range. Returns { range, contains }.
fn Office::range_contains ($range, %opts) {
    Office::_decode("range_contains",
        office__range_contains(to_json({ range => $range, cell => $opts{cell}, inner => $opts{inner} })))
}

## Smallest single A1 range enclosing BOTH $a and $b — their bounding box, the
## min/max inverse of range_intersection (always exists). NOT Excel's multi-area
## union: A1:B2 ∪ D5:E6 → A1:E6 (includes cells in neither). Returns
## { range, start, end, rows, cols }.
fn Office::range_union ($a, $b) {
    Office::_decode("range_union", office__range_union(to_json({ a => $a, b => $b })))
}
