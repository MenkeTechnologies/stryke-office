## lib/Office.stk — Office / OpenDocument / PDF import+export for stryke.
##
## Thin wrapper around the `stryke-office` cdylib's `office__*` exports,
## dlopened in-process on first `use Office`. Every format is handled
## natively in Rust — there is NO LibreOffice / soffice / pandoc subprocess.
##
## Supported (read + write):
##   spreadsheets — xlsx, ods (+ xls/csv read)   via sheet_read / sheet_write
##   documents    — docx, odt                    via doc_read / doc_write
##   presentations— pptx, odp                    via slides_read / slides_write
##   pdf          — read text + write text       via pdf_read / pdf_write
##
## Output format is chosen from the path extension; pass `format => "..."`
## to override.

package Office

## Decode the cdylib's JSON return; die on `{error}` payload.
fn Office::_decode ($name, $json) {
    val $o = from_json $json
    if (ref $o eq "HASH" && exists $o->{error}) {
        die "Office::$name: $o->{error}"
    }
    $o
}

## Return the package version string.
fn Office::version {
    Office::_decode("pkg_version", office__pkg_version("{}"))->{version}
}

# ── spreadsheets ────────────────────────────────────────────────────

## Read a spreadsheet (xlsx/ods/xls/csv). Returns an arrayref of sheets,
## each { name => "...", rows => [[cell, ...], ...] }. Numeric cells come
## back as numbers, empty cells as undef. opts: formulas => 1 to also attach
## a { formulas => [[str, ...]] } grid (aligned to rows; "" where none).
fn Office::sheet_read ($path, %opts) {
    Office::_decode("sheet_read", office__sheet_read(to_json({ path => $path, formulas => $opts{formulas}, delimiter => $opts{delimiter} })))->{sheets}
}

## Write a spreadsheet. $sheets is an arrayref of { name, rows => [[...]] }.
## Each sheet may also carry (xlsx): merges, cols, row_heights, freeze,
## autofilter, table, charts, conditional, validations, plus page setup +
## embedded content — protect, tab_color, zoom, landscape, paper,
## print_gridlines, header, footer, print_area => [r1,c1,r2,c2],
## repeat_rows => [first,last], margins => [l,r,t,b,h,f],
## notes => [{row,col,text,author?}], images => [{row,col,path}],
## sparklines => [{at:[row,col], range:[r1,c1,r2,c2], type?, markers?, high?, low?}],
## group_rows => [[first,last]], group_columns => [[first,last]],
## hide_rows => [r], hide_columns => [c], autofit => 1.
## A cell may be a rich string: { rich => [{text, bold, italic, color, ...}] }.
## opts also: properties => { title, author, subject, company, manager,
## keywords, comments, category, status } (workbook document properties).
## opts: format => "xlsx"|"ods"|"csv"|"tsv" (default: from extension),
## defined_names => [{ name, formula }] (workbook-level named ranges).
fn Office::sheet_write ($path, $sheets, %opts) {
    val $r = { path => $path, sheets => $sheets, format => $opts{format}, defined_names => $opts{defined_names}, delimiter => $opts{delimiter} }
    Office::_decode("sheet_write", office__sheet_write(to_json($r)))
}

## Concatenate spreadsheets aligned by column name (SQL UNION). $inputs is an
## arrayref of paths; rows are stacked and the output columns are the union of
## all field names (missing values blank) — so files with the same columns in
## different orders combine correctly. opts: sheet, format. Returns
## { ok, path, sources, rows, fields }.
fn Office::sheet_union ($inputs, $output, %opts) {
    Office::_decode("sheet_union",
        office__sheet_union(to_json({ inputs => $inputs, output => $output, sheet => $opts{sheet}, format => $opts{format} })))
}

## Combine spreadsheets into one. $inputs is an arrayref of paths; the target
## format comes from $output's extension (so this also converts). opts: mode =>
## "sheets" (default, keep each source sheet) | "rows" (stack all rows into one
## sheet — use for csv/tsv targets), format => override. Returns { ok, path,
## sources, sheets }.
fn Office::sheet_merge ($inputs, $output, %opts) {
    Office::_decode("sheet_merge",
        office__sheet_merge(to_json({ inputs => $inputs, output => $output, mode => $opts{mode}, format => $opts{format} })))
}

## Per-column descriptive statistics for one sheet. opts: sheet => name or
## 0-based index (default first), header => 0 if the first row is data (default
## treats it as column names). Returns { sheet, rows, columns => [{ name, count,
## numeric, blanks, sum?, min?, max?, mean? }] }.
fn Office::sheet_stats ($path, %opts) {
    Office::_decode("sheet_stats",
        office__sheet_stats(to_json({ path => $path, sheet => $opts{sheet}, header => $opts{header} })))
}

## Pandas-style numeric summary: per numeric column count/mean/std/min/25%/
## 50%/75%/max. opts: sheet, header.
fn Office::sheet_describe ($path, %opts) {
    Office::_decode("sheet_describe",
        office__sheet_describe(to_json({ path => $path, sheet => $opts{sheet}, header => $opts{header} })))
}

## Infer each column's data type (pandas df.dtypes). opts: sheet, header. Returns
## { sheet, rows, columns => [{ name, type, counts:{integer,float,bool,string,blank} }] }.
fn Office::sheet_dtypes ($path, %opts) {
    Office::_decode("sheet_dtypes",
        office__sheet_dtypes(to_json({ path => $path, sheet => $opts{sheet}, header => $opts{header} })))
}

## Most-frequent value (mode) of each column. opts: sheet, header. Returns
## { sheet, rows, columns => [{ name, mode, count }] }.
fn Office::sheet_mode ($path, %opts) {
    Office::_decode("sheet_mode",
        office__sheet_mode(to_json({ path => $path, sheet => $opts{sheet}, header => $opts{header} })))
}

## Compute an arbitrary percentile of a numeric column ($q in 0.0..=1.0, e.g.
## 0.9 for p90). opts: sheet, header. Returns { column, q, value, count }.
fn Office::sheet_quantile ($path, $column, $q, %opts) {
    Office::_decode("sheet_quantile",
        office__sheet_quantile(to_json({ path => $path, column => $column, q => $q, sheet => $opts{sheet}, header => $opts{header} })))
}

## Single-column scalar aggregate. opts: agg (sum/mean/min/max/count/median),
## sheet, header. Returns { column, agg, value, count }.
fn Office::sheet_agg ($path, $column, %opts) {
    Office::_decode("sheet_agg",
        office__sheet_agg(to_json({ path => $path, column => $column, agg => $opts{agg}, sheet => $opts{sheet}, header => $opts{header} })))
}

## Render a numeric column as a Unicode block sparkline string (▁▂▃▄▅▆▇█). opts:
## sheet, header. Returns { column, sparkline, count, min, max }.
fn Office::sheet_sparkline ($path, $column, %opts) {
    Office::_decode("sheet_sparkline",
        office__sheet_sparkline(to_json({ path => $path, column => $column, sheet => $opts{sheet}, header => $opts{header} })))
}

## Pearson correlation matrix between numeric columns (pandas df.corr()).
## opts: sheet, header. Returns { sheet, columns, matrix }.
fn Office::sheet_corr ($path, %opts) {
    Office::_decode("sheet_corr",
        office__sheet_corr(to_json({ path => $path, sheet => $opts{sheet}, header => $opts{header} })))
}

## Render a spreadsheet as a GitHub-flavored Markdown table. opts: output (write
## to a .md file; omit to return the text), sheet, header. Returns { ok, rows,
## cols, markdown, path? }.
fn Office::sheet_to_md ($path, %opts) {
    Office::_decode("sheet_to_md",
        office__sheet_to_md(to_json({ path => $path, output => $opts{output}, sheet => $opts{sheet}, header => $opts{header} })))
}

## Emit SQL INSERT statements for a sheet. $table is the target table. opts:
## output (.sql file; omit to return), columns (override names), batch (rows per
## statement, default 1), sheet, header. Returns { ok, statements, rows, sql, path? }.
fn Office::sheet_to_sql ($path, $table, %opts) {
    Office::_decode("sheet_to_sql",
        office__sheet_to_sql(to_json({ path => $path, table => $table, output => $opts{output}, columns => $opts{columns}, batch => $opts{batch}, sheet => $opts{sheet}, header => $opts{header} })))
}

## Render a sheet as a LaTeX tabular. opts: output (.tex; omit to return), align
## (column spec e.g. "lcr"), booktabs (\toprule rules), caption (wrap in a table
## float), sheet, header. Returns { ok, rows, cols, latex, path? }.
fn Office::sheet_to_latex ($path, %opts) {
    Office::_decode("sheet_to_latex",
        office__sheet_to_latex(to_json({ path => $path, output => $opts{output}, align => $opts{align}, booktabs => $opts{booktabs}, caption => $opts{caption}, sheet => $opts{sheet}, header => $opts{header} })))
}

## Parse a GitHub-flavored Markdown table into a spreadsheet (inverse of
## sheet_to_md). opts: markdown (table text) or path (.md file), name, format.
## Returns { ok, path, rows, cols }.
fn Office::md_to_sheet ($output, %opts) {
    Office::_decode("md_to_sheet",
        office__md_to_sheet(to_json({ output => $output, markdown => $opts{markdown}, path => $opts{path}, name => $opts{name}, format => $opts{format} })))
}

## Render a spreadsheet as an HTML table. opts: output (write .html; omit to
## return markup), sheet, header, title, full (wrap in a full <html> document).
## Returns { ok, rows, cols, html, path? }.
fn Office::sheet_to_html ($path, %opts) {
    Office::_decode("sheet_to_html",
        office__sheet_to_html(to_json({ path => $path, output => $opts{output}, sheet => $opts{sheet}, header => $opts{header}, title => $opts{title}, full => $opts{full} })))
}

## Render a sheet as an aligned plain-text table (terminal-friendly). opts:
## output, sheet, header, border (ASCII grid). Returns { ok, rows, cols, text, path? }.
fn Office::sheet_to_text ($path, %opts) {
    Office::_decode("sheet_to_text",
        office__sheet_to_text(to_json({ path => $path, output => $opts{output}, sheet => $opts{sheet}, header => $opts{header}, border => $opts{border} })))
}

## Read a single cell by A1 reference (e.g. "B2"). opts: sheet. Returns
## { cell, row, col, value }.
fn Office::sheet_get_cell ($path, $cell, %opts) {
    Office::_decode("sheet_get_cell",
        office__sheet_get_cell(to_json({ path => $path, cell => $cell, sheet => $opts{sheet} })))
}

## Set a single cell by A1 reference, growing the grid as needed. opts: value,
## output (default in place), sheet, format. Returns { ok, path, cell }.
fn Office::sheet_set_cell ($path, $cell, %opts) {
    Office::_decode("sheet_set_cell",
        office__sheet_set_cell(to_json({ path => $path, cell => $cell, value => $opts{value}, output => $opts{output}, sheet => $opts{sheet}, format => $opts{format} })))
}

## Read a rectangular A1 range (e.g. "A1:C3") as a subgrid. opts: sheet.
## Returns { range, nrows, ncols, rows }.
fn Office::sheet_get_range ($path, $range, %opts) {
    Office::_decode("sheet_get_range",
        office__sheet_get_range(to_json({ path => $path, range => $range, sheet => $opts{sheet} })))
}

## Paste a 2D block of $values at a top-left A1 $cell, growing the grid. opts:
## output (default in place), sheet, format. Returns { ok, path, cells }.
fn Office::sheet_set_range ($path, $cell, $values, %opts) {
    Office::_decode("sheet_set_range",
        office__sheet_set_range(to_json({ path => $path, cell => $cell, values => $values, output => $opts{output}, sheet => $opts{sheet}, format => $opts{format} })))
}

## Insert blank rows at a 1-based position (shifts later rows down). opts: at
## (default 1), count (default 1), output, sheet, format. Returns { ok, path, inserted }.
fn Office::sheet_insert_rows ($path, %opts) {
    Office::_decode("sheet_insert_rows",
        office__sheet_insert_rows(to_json({ path => $path, at => $opts{at}, count => $opts{count}, output => $opts{output}, sheet => $opts{sheet}, format => $opts{format} })))
}

## Delete rows starting at a 1-based position. opts: at (required), count
## (default 1), output, sheet, format. Returns { ok, path, deleted }.
fn Office::sheet_delete_rows ($path, $at, %opts) {
    Office::_decode("sheet_delete_rows",
        office__sheet_delete_rows(to_json({ path => $path, at => $at, count => $opts{count}, output => $opts{output}, sheet => $opts{sheet}, format => $opts{format} })))
}

## Insert a column at a 1-based position (shifts later columns right). opts: at
## (default 1), name (header), value (data fill), output, sheet, header, format.
## Returns { ok, path, at }.
fn Office::sheet_insert_column ($path, %opts) {
    Office::_decode("sheet_insert_column",
        office__sheet_insert_column(to_json({ path => $path, at => $opts{at}, name => $opts{name}, value => $opts{value}, output => $opts{output}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Append a running-total (cumulative sum) column for a numeric column. opts:
## into (new header), sheet, header, format. Returns { ok, path, column }.
fn Office::sheet_cumsum ($path, $column, $output, %opts) {
    Office::_decode("sheet_cumsum",
        office__sheet_cumsum(to_json({ path => $path, column => $column, output => $output, into => $opts{into}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Append a cumulative running max/min/product column (pandas cummax/cummin/
## cumprod). opts: agg (max|min|prod, default max), into, decimals, sheet, header,
## format. Returns { ok, path, column }.
fn Office::sheet_cumulative ($path, $column, $output, %opts) {
    Office::_decode("sheet_cumulative",
        office__sheet_cumulative(to_json({ path => $path, column => $column, output => $output, agg => $opts{agg}, into => $opts{into}, decimals => $opts{decimals}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Append a percent-of-total column (value / column sum * 100). opts: into,
## decimals (round), sheet, header, format. Returns { ok, path, column }.
fn Office::sheet_pct ($path, $column, $output, %opts) {
    Office::_decode("sheet_pct",
        office__sheet_pct(to_json({ path => $path, column => $column, output => $output, into => $opts{into}, decimals => $opts{decimals}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Append a "percent of group total" column: $value as a % of its $group's sum
## (group-aware counterpart to sheet_pct). opts: into, decimals, sheet, header,
## format. Returns { ok, path, column }.
fn Office::sheet_group_pct ($path, $output, $group, $value, %opts) {
    Office::_decode("sheet_group_pct",
        office__sheet_group_pct(to_json({ path => $path, output => $output, group => $group, value => $value, into => $opts{into}, decimals => $opts{decimals}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Append a group-wise running total column (running balance per group, in row
## order; group-aware counterpart to sheet_cumsum). opts: into, decimals, sheet,
## header, format. Returns { ok, path, column }.
fn Office::sheet_running ($path, $output, $group, $value, %opts) {
    Office::_decode("sheet_running",
        office__sheet_running(to_json({ path => $path, output => $output, group => $group, value => $value, into => $opts{into}, decimals => $opts{decimals}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Append a normalized column (method => "minmax" 0..1 or "zscore"). opts: into,
## method, decimals, sheet, header, format. Returns { ok, path, column }.
fn Office::sheet_normalize ($path, $column, $output, %opts) {
    Office::_decode("sheet_normalize",
        office__sheet_normalize(to_json({ path => $path, column => $column, output => $output, method => $opts{method}, into => $opts{into}, decimals => $opts{decimals}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Append a moving-average (rolling mean) column over a $window of rows. opts:
## into, decimals, sheet, header, format. Returns { ok, path, column }.
fn Office::sheet_movavg ($path, $column, $window, $output, %opts) {
    Office::_decode("sheet_movavg",
        office__sheet_movavg(to_json({ path => $path, column => $column, window => $window, output => $output, into => $opts{into}, decimals => $opts{decimals}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Append a generalized rolling-window aggregate column (superset of movavg).
## opts: agg (sum|mean|min|max|median|std, default mean), into, decimals, sheet,
## header, format. Returns { ok, path, column }.
fn Office::sheet_rolling ($path, $column, $window, $output, %opts) {
    Office::_decode("sheet_rolling",
        office__sheet_rolling(to_json({ path => $path, column => $column, window => $window, output => $output, agg => $opts{agg}, into => $opts{into}, decimals => $opts{decimals}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Append a row-over-row difference (current - previous) column. opts: into,
## decimals, sheet, header, format. Returns { ok, path, column }.
fn Office::sheet_delta ($path, $column, $output, %opts) {
    Office::_decode("sheet_delta",
        office__sheet_delta(to_json({ path => $path, column => $column, output => $output, into => $opts{into}, decimals => $opts{decimals}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Append a row-over-row percentage-change column (pandas pct_change): relative
## counterpart to sheet_delta. opts: fraction (1 => raw ratio, default percent),
## into, decimals, sheet, header, format. Returns { ok, path, column }.
fn Office::sheet_pct_change ($path, $column, $output, %opts) {
    Office::_decode("sheet_pct_change",
        office__sheet_pct_change(to_json({ path => $path, column => $column, output => $output, fraction => $opts{fraction}, into => $opts{into}, decimals => $opts{decimals}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Append a shifted (lag/lead) copy of a column (pandas Series.shift). opts:
## periods (default 1; negative = lead), fill (vacated cells; default blank),
## into, sheet, header, format. Returns { ok, path, column }.
fn Office::sheet_shift ($path, $column, $output, %opts) {
    Office::_decode("sheet_shift",
        office__sheet_shift(to_json({ path => $path, column => $column, output => $output, periods => $opts{periods}, fill => $opts{fill}, into => $opts{into}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Clamp a numeric column to a range (cap outliers). opts: min and/or max
## (>=1 required), into (new column; default in place), sheet, header, format.
## Returns { ok, path, clamped }.
fn Office::sheet_clamp ($path, $column, $output, %opts) {
    Office::_decode("sheet_clamp",
        office__sheet_clamp(to_json({ path => $path, column => $column, output => $output, min => $opts{min}, max => $opts{max}, into => $opts{into}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Winsorize a numeric column: clip values to percentile bounds from the data
## (robust outlier capping). opts: lower (default 0.05), upper (default 0.95),
## into, decimals, sheet, header, format. Returns { ok, path, clipped, low, high }.
fn Office::sheet_winsorize ($path, $column, $output, %opts) {
    Office::_decode("sheet_winsorize",
        office__sheet_winsorize(to_json({ path => $path, column => $column, output => $output, lower => $opts{lower}, upper => $opts{upper}, into => $opts{into}, decimals => $opts{decimals}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Rename a column's header (not the sheet tab). opts: sheet, format.
## Returns { ok, path, column }.
fn Office::sheet_rename_column ($path, $column, $to, $output, %opts) {
    Office::_decode("sheet_rename_column",
        office__sheet_rename_column(to_json({ path => $path, column => $column, to => $to, output => $output, sheet => $opts{sheet}, format => $opts{format} })))
}

## Bulk-rename headers via a $map of { old => new } (multi-column rename). opts:
## sheet, header, format. Returns { ok, path, renamed }.
fn Office::sheet_rename_columns ($path, $output, $map, %opts) {
    Office::_decode("sheet_rename_columns",
        office__sheet_rename_columns(to_json({ path => $path, output => $output, map => $map, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Explode a delimited column into multiple rows (SQL unnest; inverse of
## group_concat). opts: sep, trim, sheet, header, format. Returns { ok, path, rows }.
fn Office::sheet_explode ($path, $column, $output, %opts) {
    Office::_decode("sheet_explode",
        office__sheet_explode(to_json({ path => $path, column => $column, output => $output, sep => $opts{sep}, trim => $opts{trim}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Recode a column's values via a $mapping hashref { old => new }. opts: default
## (for unmapped), into (new column; default in place), sheet, header, format.
## Returns { ok, path, mapped }.
fn Office::sheet_map ($path, $column, $mapping, $output, %opts) {
    Office::_decode("sheet_map",
        office__sheet_map(to_json({ path => $path, column => $column, mapping => $mapping, output => $output, default => $opts{default}, into => $opts{into}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Partition a sheet into one file per distinct value of $column. opts: prefix,
## format, header, sheet. Returns { count, files }.
fn Office::sheet_partition ($path, $column, $dir, %opts) {
    Office::_decode("sheet_partition",
        office__sheet_partition(to_json({ path => $path, column => $column, dir => $dir, prefix => $opts{prefix}, format => $opts{format}, header => $opts{header}, sheet => $opts{sheet} })))
}

## Split a sheet into one tab per distinct value of $column, in a single output
## workbook (single-file counterpart to sheet_partition). opts: header, sheet,
## format. Returns { ok, path, sheets, groups }.
fn Office::sheet_split_by ($path, $output, $column, %opts) {
    Office::_decode("sheet_split_by",
        office__sheet_split_by(to_json({ path => $path, output => $output, column => $column, header => $opts{header}, sheet => $opts{sheet}, format => $opts{format} })))
}

## Sort by multiple columns. $keys is an arrayref of { column, descending? } in
## priority order. opts: sheet, header, format. Returns { ok, path, sorted }.
fn Office::sheet_multisort ($path, $keys, $output, %opts) {
    Office::_decode("sheet_multisort",
        office__sheet_multisort(to_json({ path => $path, keys => $keys, output => $output, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Find cells matching $query across a workbook. opts: ignore_case => 1,
## whole => 1 (exact cell match instead of substring), sheet => restrict to one
## sheet name. Returns { count, matches => [{ sheet, row, col, ref, value }] }
## with 1-based row/col and an A1-style ref.
fn Office::sheet_find ($path, $query, %opts) {
    Office::_decode("sheet_find",
        office__sheet_find(to_json({ path => $path, query => $query, ignore_case => $opts{ignore_case}, whole => $opts{whole}, sheet => $opts{sheet} })))
}

## Read a sheet as records — the first row is field names, each later row an
## object keyed by them. opts: sheet => name or 0-based index. Returns
## { fields, count, records => [{ field => value }] }.
fn Office::sheet_records ($path, %opts) {
    Office::_decode("sheet_records",
        office__sheet_records(to_json({ path => $path, sheet => $opts{sheet} })))
}

## Build a { key => value } hash from a $key column and a $value column (lookup /
## config map). opts: sheet, header. Last row wins on duplicate keys; blank keys
## skipped. Returns { map, count }.
fn Office::sheet_to_map ($path, $key, $value, %opts) {
    Office::_decode("sheet_to_map",
        office__sheet_to_map(to_json({ path => $path, key => $key, value => $value, sheet => $opts{sheet}, header => $opts{header} })))
}

## Write records (an arrayref of hashes) to a spreadsheet: a header row of field
## names plus one row per record. opts: fields => explicit column order
## (default: keys in first-seen order), sheet_name => "Sheet1", format =>
## override (target ext converts). Returns { ok, path, rows, fields }.
fn Office::records_write ($path, $records, %opts) {
    Office::_decode("records_write",
        office__records_write(to_json({ path => $path, records => $records, fields => $opts{fields}, sheet_name => $opts{sheet_name}, format => $opts{format} })))
}

## Export a sheet to a JSON file (array of header-keyed objects). opts: sheet =>
## name/index, pretty => 0 for compact. Returns { ok, path, count }.
fn Office::sheet_to_json ($path, $output, %opts) {
    Office::_decode("sheet_to_json",
        office__sheet_to_json(to_json({ path => $path, output => $output, sheet => $opts{sheet}, pretty => $opts{pretty} })))
}

## Export a sheet as JSON Lines (NDJSON): one header-keyed JSON object per data
## row. opts: sheet. Returns { ok, path, count }.
fn Office::sheet_to_ndjson ($path, $output, %opts) {
    Office::_decode("sheet_to_ndjson",
        office__sheet_to_ndjson(to_json({ path => $path, output => $output, sheet => $opts{sheet} })))
}

## Import JSON Lines (NDJSON) into a spreadsheet (inverse of sheet_to_ndjson).
## opts: input (.jsonl file) or ndjson (text), fields, sheet_name, format.
## Returns { ok, path, rows, fields }.
fn Office::ndjson_to_sheet ($output, %opts) {
    Office::_decode("ndjson_to_sheet",
        office__ndjson_to_sheet(to_json({ output => $output, input => $opts{input}, ndjson => $opts{ndjson}, fields => $opts{fields}, sheet_name => $opts{sheet_name}, format => $opts{format} })))
}

## Import a JSON file (array of objects) into a spreadsheet. opts: fields =>
## explicit column order, sheet_name, format => override. Returns
## { ok, path, rows, fields }.
fn Office::json_to_sheet ($input, $output, %opts) {
    Office::_decode("json_to_sheet",
        office__json_to_sheet(to_json({ input => $input, output => $output, fields => $opts{fields}, sheet_name => $opts{sheet_name}, format => $opts{format} })))
}

## Sort a sheet's data rows by $by (column name or 0-based index), preserving
## the header. opts: sheet => name/index, descending => 1, numeric => 1|0
## (default auto-detect), ignore_case => 1 (text mode), header => 0 if the first
## row is data, format => override. Returns { ok, path, sorted, column }.
fn Office::sheet_sort ($path, $by, $output, %opts) {
    Office::_decode("sheet_sort",
        office__sheet_sort(to_json({ path => $path, by => $by, output => $output, sheet => $opts{sheet}, descending => $opts{descending}, numeric => $opts{numeric}, ignore_case => $opts{ignore_case}, header => $opts{header}, format => $opts{format} })))
}

## Append a rank column by $by without reordering (Excel RANK / SQL RANK()).
## opts: ascending, dense, name, sheet, header, format. Returns { ok, path, ranked }.
fn Office::sheet_rank ($path, $by, $output, %opts) {
    Office::_decode("sheet_rank",
        office__sheet_rank(to_json({ path => $path, by => $by, output => $output, ascending => $opts{ascending}, dense => $opts{dense}, name => $opts{name}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Keep only rows whose $by column satisfies a predicate. opts: op => one of
## eq|ne|contains|not_contains|gt|lt|ge|le (default eq), value => comparison
## value, sheet, ignore_case => 1, header => 0 if first row is data, format =>
## override. Returns { ok, path, kept, removed, column }.
fn Office::sheet_filter ($path, $by, $output, %opts) {
    Office::_decode("sheet_filter",
        office__sheet_filter(to_json({ path => $path, by => $by, output => $output, op => $opts{op}, value => $opts{value}, sheet => $opts{sheet}, ignore_case => $opts{ignore_case}, header => $opts{header}, format => $opts{format} })))
}

## Append a flag column marking rows where $by satisfies a predicate (keeps all
## rows). opts: op (default eq), value, true_value/false_value (default 1/0),
## into (default "flag"), ignore_case, sheet, header, format. Returns
## { ok, path, column, flagged }.
fn Office::sheet_flag ($path, $by, $output, %opts) {
    Office::_decode("sheet_flag",
        office__sheet_flag(to_json({ path => $path, by => $by, output => $output, op => $opts{op}, value => $opts{value}, true_value => $opts{true_value}, false_value => $opts{false_value}, into => $opts{into}, ignore_case => $opts{ignore_case}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## One-hot encode a categorical column into 0/1 indicator columns (pandas
## get_dummies). opts: prefix (default column name), drop (remove original),
## sheet, header, format. Returns { ok, path, categories }.
fn Office::sheet_onehot ($path, $output, $column, %opts) {
    Office::_decode("sheet_onehot",
        office__sheet_onehot(to_json({ path => $path, output => $output, column => $column, prefix => $opts{prefix}, drop => $opts{drop}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Group rows by $group_by and aggregate (SQL GROUP BY). opts: value => column
## to aggregate (required for sum/mean/min/max), agg => count|sum|mean|min|max
## (default count), sheet, header => 0 if first row is data, format => override.
## Output is a two-column sheet sorted by group. Returns { ok, path, groups }.
fn Office::sheet_aggregate ($path, $group_by, $output, %opts) {
    Office::_decode("sheet_aggregate",
        office__sheet_aggregate(to_json({ path => $path, group_by => $group_by, output => $output, value => $opts{value}, agg => $opts{agg}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Group by a column and concatenate another column's values per group (SQL
## GROUP_CONCAT). opts: sep, distinct, sheet, header, format. Returns { ok, path, groups }.
fn Office::sheet_group_concat ($path, $group_by, $value, $output, %opts) {
    Office::_decode("sheet_group_concat",
        office__sheet_group_concat(to_json({ path => $path, group_by => $group_by, value => $value, output => $output, sep => $opts{sep}, distinct => $opts{distinct}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## VLOOKUP: find $key in the $lookup column, return the cell from $result.
## opts: ignore_case, sheet, header. Returns { found, value, row }.
fn Office::sheet_lookup ($path, $lookup, $key, $result, %opts) {
    Office::_decode("sheet_lookup",
        office__sheet_lookup(to_json({ path => $path, lookup => $lookup, key => $key, result => $result, ignore_case => $opts{ignore_case}, sheet => $opts{sheet}, header => $opts{header} })))
}

## COUNTIF: count rows where $column matches a predicate. opts: op (default eq),
## value, ignore_case, sheet, header. Returns { count }.
fn Office::sheet_countif ($path, $column, %opts) {
    Office::_decode("sheet_countif",
        office__sheet_countif(to_json({ path => $path, column => $column, op => $opts{op}, value => $opts{value}, ignore_case => $opts{ignore_case}, sheet => $opts{sheet}, header => $opts{header} })))
}

## SUMIF: sum a numeric column over rows where $column matches a predicate. opts:
## op, value, sum (column to sum; default $column), ignore_case, sheet, header.
## Returns { sum, count }.
fn Office::sheet_sumif ($path, $column, %opts) {
    Office::_decode("sheet_sumif",
        office__sheet_sumif(to_json({ path => $path, column => $column, op => $opts{op}, value => $opts{value}, sum => $opts{sum}, ignore_case => $opts{ignore_case}, sheet => $opts{sheet}, header => $opts{header} })))
}

## Value-counts of one column, sorted by frequency (pandas value_counts).
## opts: sheet, header, ignore_case, top. Returns { column, total, distinct, values }.
fn Office::sheet_freq ($path, $column, %opts) {
    Office::_decode("sheet_freq",
        office__sheet_freq(to_json({ path => $path, column => $column, sheet => $opts{sheet}, header => $opts{header}, ignore_case => $opts{ignore_case}, top => $opts{top} })))
}

## Distinct values of a column (SQL DISTINCT). opts: sorted, ignore_case, sheet,
## header. Returns { column, count, values }.
fn Office::sheet_unique ($path, $column, %opts) {
    Office::_decode("sheet_unique",
        office__sheet_unique(to_json({ path => $path, column => $column, sorted => $opts{sorted}, ignore_case => $opts{ignore_case}, sheet => $opts{sheet}, header => $opts{header} })))
}

## Split one column into several by a delimiter (Excel Text to Columns). opts:
## delimiter, into, max, trim, keep, sheet, header, format. Returns { ok, path, columns }.
fn Office::sheet_split_column ($path, $column, $output, %opts) {
    Office::_decode("sheet_split_column",
        office__sheet_split_column(to_json({ path => $path, column => $column, output => $output, delimiter => $opts{delimiter}, into => $opts{into}, max => $opts{max}, trim => $opts{trim}, keep => $opts{keep}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Join several columns into one with a separator (Excel TEXTJOIN; inverse of
## sheet_split_column). opts: separator, into, skip_blanks, keep, sheet, header,
## format. Returns { ok, path, into }.
fn Office::sheet_concat_columns ($path, $columns, $output, %opts) {
    Office::_decode("sheet_concat_columns",
        office__sheet_concat_columns(to_json({ path => $path, columns => $columns, output => $output, separator => $opts{separator}, into => $opts{into}, skip_blanks => $opts{skip_blanks}, keep => $opts{keep}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Join two spreadsheets on a key column (SQL JOIN). opts: on => shared key
## field name (or left_on + right_on), how => "inner" (default) | left | right | outer,
## left_sheet / right_sheet => name/index, format => override. Output columns are
## the left fields then the right fields (right key dropped; colliding right
## names get a _right suffix). Returns { ok, path, rows, matched }.
fn Office::sheet_join ($left, $right, $output, %opts) {
    Office::_decode("sheet_join",
        office__sheet_join(to_json({ left => $left, right => $right, output => $output, on => $opts{on}, left_on => $opts{left_on}, right_on => $opts{right_on}, how => $opts{how}, left_sheet => $opts{left_sheet}, right_sheet => $opts{right_sheet}, format => $opts{format} })))
}

## Build a pivot table: group rows by $rows column and columns by $cols column,
## aggregating $opts{value} into each cell (Excel PivotTable). opts: value =>
## aggregated column (required for sum/mean/min/max), agg => count|sum|mean|min|
## max (default sum), sheet, header => 0 if first row is data, format. Output is
## a matrix sheet. Returns { ok, path, rows, cols }.
fn Office::sheet_pivot ($path, $rows, $cols, $output, %opts) {
    Office::_decode("sheet_pivot",
        office__sheet_pivot(to_json({ path => $path, rows => $rows, cols => $cols, output => $output, value => $opts{value}, agg => $opts{agg}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Unpivot (melt) a sheet from wide to long. opts: id_vars => column(s) to keep
## (name/index or arrayref), value_vars => columns to unpivot (default: all
## non-id), var_name (default "variable"), value_name (default "value"), sheet,
## header => 0 if first row is data, format. Returns { ok, path, rows }.
fn Office::sheet_unpivot ($path, $output, %opts) {
    Office::_decode("sheet_unpivot",
        office__sheet_unpivot(to_json({ path => $path, output => $output, id_vars => $opts{id_vars}, value_vars => $opts{value_vars}, var_name => $opts{var_name}, value_name => $opts{value_name}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Project/reorder columns. $columns is an arrayref of column names or 0-based
## indices in the desired output order. opts: sheet, header => 0 if first row is
## data, format => override. Returns { ok, path, columns }.
fn Office::sheet_select ($path, $columns, $output, %opts) {
    Office::_decode("sheet_select",
        office__sheet_select(to_json({ path => $path, columns => $columns, output => $output, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Find/replace text in a sheet's cells (works on any format, incl. csv; only
## string cells are touched). opts: replace => "" default, ignore_case => 1,
## whole => 1 (replace whole cell vs substring), column => restrict, sheet,
## output (default in place), header => 0 if first row is data, format. Returns
## { ok, path, replaced }.
fn Office::sheet_replace ($path, $find, %opts) {
    Office::_decode("sheet_replace",
        office__sheet_replace(to_json({ path => $path, find => $find, replace => $opts{replace}, ignore_case => $opts{ignore_case}, whole => $opts{whole}, column => $opts{column}, sheet => $opts{sheet}, output => $opts{output}, header => $opts{header}, format => $opts{format} })))
}

## Append a totals row summing each numeric column. opts: label => first-cell
## text (default "Total"), sheet, header => 0 if first row is data, output
## (default in place), format. Returns { ok, path, totals }.
fn Office::sheet_totals ($path, %opts) {
    Office::_decode("sheet_totals",
        office__sheet_totals(to_json({ path => $path, label => $opts{label}, sheet => $opts{sheet}, header => $opts{header}, output => $opts{output}, format => $opts{format} })))
}

## Insert group-wise subtotal rows (Excel Data>Subtotal). Operates on consecutive
## runs — sort by the group column first. opts: group (column; required), value
## (column or arrayref; required), agg (sum|mean|min|max|count, default sum),
## label (default "Total"), grand (default 1), output, sheet, header, format.
## Returns { ok, path, groups }.
fn Office::sheet_subtotal ($path, %opts) {
    Office::_decode("sheet_subtotal",
        office__sheet_subtotal(to_json({ path => $path, group => $opts{group}, value => $opts{value}, agg => $opts{agg}, label => $opts{label}, grand => $opts{grand}, output => $opts{output}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Add a derived column to a sheet. $name is the new header. opts: value => a
## constant for every data row, or concat => [columns] joined by sep (default
## " "); sheet, output (default in place), header => 0 if first row is data,
## format. Returns { ok, path, column }.
fn Office::sheet_add_column ($path, $name, %opts) {
    Office::_decode("sheet_add_column",
        office__sheet_add_column(to_json({ path => $path, name => $name, value => $opts{value}, concat => $opts{concat}, sep => $opts{sep}, sheet => $opts{sheet}, output => $opts{output}, header => $opts{header}, format => $opts{format} })))
}

## Drop columns from a sheet (complement of sheet_select). $columns is an
## arrayref of column names/indices to remove. opts: sheet, header => 0 if first
## row is data, format => override. Returns { ok, path, columns } (kept count).
fn Office::sheet_drop ($path, $columns, $output, %opts) {
    Office::_decode("sheet_drop",
        office__sheet_drop(to_json({ path => $path, columns => $columns, output => $output, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Transpose a sheet — rows become columns and vice versa. opts: sheet =>
## name/index, format => override. Returns { ok, path, rows, columns }.
fn Office::sheet_transpose ($path, $output, %opts) {
    Office::_decode("sheet_transpose",
        office__sheet_transpose(to_json({ path => $path, output => $output, sheet => $opts{sheet}, format => $opts{format} })))
}

## Append rows to an existing sheet. Provide either rows => [[...], ...] (raw)
## or records => [{...}] (mapped to the sheet's header). opts: output (default:
## in place), sheet => name/index, format => override. Returns { ok, path,
## added, rows }.
fn Office::sheet_append ($path, %opts) {
    Office::_decode("sheet_append",
        office__sheet_append(to_json({ path => $path, rows => $opts{rows}, records => $opts{records}, output => $opts{output}, sheet => $opts{sheet}, format => $opts{format} })))
}

## Concatenate two row-aligned sheets side by side (pandas concat axis=1).
## $right is the second spreadsheet path. opts: sheet (left selector), right_sheet
## (right selector), format. Returns { ok, path, rows, columns }.
fn Office::sheet_hstack ($path, $right, $output, %opts) {
    Office::_decode("sheet_hstack",
        office__sheet_hstack(to_json({ path => $path, right => $right, output => $output, sheet => $opts{sheet}, right_sheet => $opts{right_sheet}, format => $opts{format} })))
}

## Validate a sheet's cells against per-column rules. $rules is an arrayref of
## { column => name/index, type => "number"|"int"|"nonempty", min, max,
## allowed => [values] }. opts: sheet, header => 0 if first row is data. Returns
## { valid, count, violations => [{ ref, row, col, column, rule, value }] }.
fn Office::sheet_validate ($path, $rules, %opts) {
    Office::_decode("sheet_validate",
        office__sheet_validate(to_json({ path => $path, rules => $rules, sheet => $opts{sheet}, header => $opts{header} })))
}

## Turn each spreadsheet row into a slide. $output is a pptx/odp path. opts:
## title_field => column whose value titles each slide (default: first column),
## sheet, format. Remaining fields become "field: value" body lines. Returns
## { ok, path, slides }.
fn Office::sheet_to_slides ($path, $output, %opts) {
    Office::_decode("sheet_to_slides",
        office__sheet_to_slides(to_json({ path => $path, output => $output, title_field => $opts{title_field}, sheet => $opts{sheet}, format => $opts{format} })))
}

## Universal file inspector: identify any office/image file by extension and
## return a type-appropriate summary. Returns { type, format, path, ... } —
## extra fields per type (pdf pages/geometry, spreadsheet sheets, document word
## counts, presentation slide stats, image width/height).
fn Office::info ($path) {
    Office::_decode("info", office__info(to_json({ path => $path })))
}

## Workbook overview: name + dimensions of every sheet. Returns { count,
## sheets => [{ name, rows, cols }] }.
fn Office::sheet_info ($path) {
    Office::_decode("sheet_info", office__sheet_info(to_json({ path => $path })))
}

## Compare two sheets cell by cell. opts: sheet => selector for both, left_sheet
## / right_sheet => per-side override. Returns { count, changed => [{ ref, row,
## col, left, right }], left_rows, right_rows } for cells that differ.
fn Office::sheet_diff ($left, $right, %opts) {
    Office::_decode("sheet_diff",
        office__sheet_diff(to_json({ left => $left, right => $right, sheet => $opts{sheet}, left_sheet => $opts{left_sheet}, right_sheet => $opts{right_sheet} })))
}

## Add a new sheet to a workbook. $name is the sheet name. opts: rows =>
## [[cell,...]] (default empty), position => 0-based insert index (default
## append), output (default in place), format. Returns { ok, path, sheets }.
fn Office::sheet_add ($path, $name, %opts) {
    Office::_decode("sheet_add",
        office__sheet_add(to_json({ path => $path, name => $name, rows => $opts{rows}, position => $opts{position}, output => $opts{output}, format => $opts{format} })))
}

## Duplicate a worksheet within a workbook. opts: sheet (source name/index;
## required), name (the copy's name; default "{source} (copy)"), position
## (default after source), output (default in place), format. Returns
## { ok, path, name, sheets }.
fn Office::sheet_copy ($path, %opts) {
    Office::_decode("sheet_copy",
        office__sheet_copy(to_json({ path => $path, sheet => $opts{sheet}, name => $opts{name}, position => $opts{position}, output => $opts{output}, format => $opts{format} })))
}

## Reorder (and/or subset) the sheets of a workbook. $order is an arrayref of
## sheet names/indices in the desired order; omitted sheets are dropped. opts:
## output (default in place), format. Returns { ok, path, sheets }.
fn Office::sheet_reorder ($path, $order, %opts) {
    Office::_decode("sheet_reorder",
        office__sheet_reorder(to_json({ path => $path, order => $order, output => $opts{output}, format => $opts{format} })))
}

## Remove a sheet from a workbook. $sheet selects which (name or index). opts:
## output (default in place), format. Errors if it would remove the only sheet.
## Returns { ok, path, removed, sheets }.
fn Office::sheet_remove ($path, $sheet, %opts) {
    Office::_decode("sheet_remove",
        office__sheet_remove(to_json({ path => $path, sheet => $sheet, output => $opts{output}, format => $opts{format} })))
}

## Rename a sheet in a workbook. opts: from => sheet to rename (name/index,
## default first), output (default: in place), format. $to is the new name.
## Returns { ok, path, renamed }.
fn Office::sheet_rename ($path, $to, %opts) {
    Office::_decode("sheet_rename",
        office__sheet_rename(to_json({ path => $path, to => $to, from => $opts{from}, output => $opts{output}, format => $opts{format} })))
}

## Top-N rows by a column (sort then take N). $by is the column. opts: n =>
## count (default 10), ascending => 1 (smallest first; default largest),
## numeric, sheet, header, output, format. Returns { ok, path, rows }.
fn Office::sheet_top ($path, $by, $output, %opts) {
    Office::_decode("sheet_top",
        office__sheet_top(to_json({ path => $path, by => $by, output => $output, n => $opts{n}, ascending => $opts{ascending}, numeric => $opts{numeric}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Keep only the first (or last) N data rows of a sheet. opts: n => row count
## (default 10), tail => 1 to take the last N, header => 0 to drop the header,
## sheet, format => override. Returns { ok, path, rows }.
fn Office::sheet_head ($path, $output, %opts) {
    Office::_decode("sheet_head",
        office__sheet_head(to_json({ path => $path, output => $output, n => $opts{n}, tail => $opts{tail}, header => $opts{header}, sheet => $opts{sheet}, format => $opts{format} })))
}

## Randomly sample N data rows (header kept), reproducible via a seed. opts: n
## (default 10), seed, header, sheet, format. Returns { ok, path, rows }.
fn Office::sheet_sample ($path, $output, %opts) {
    Office::_decode("sheet_sample",
        office__sheet_sample(to_json({ path => $path, output => $output, n => $opts{n}, seed => $opts{seed}, header => $opts{header}, sheet => $opts{sheet}, format => $opts{format} })))
}

## Apply a named transform to one column: upper/lower/trim/title or
## round/floor/ceil/abs/int. opts: digits (for round), into (new column; default
## replace), sheet, header, format. Returns { ok, path, transformed }.
fn Office::sheet_transform ($path, $column, $op, $output, %opts) {
    Office::_decode("sheet_transform",
        office__sheet_transform(to_json({ path => $path, column => $column, op => $op, output => $output, digits => $opts{digits}, into => $opts{into}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Type-coerce cells in column(s) — clean imported data. opts: by (column(s);
## default all), type (number|int|string|bool, default number; `number` parses
## currency/commas/percent/accounting negatives), sheet, header, format. Returns
## { ok, path, cast }.
fn Office::sheet_cast ($path, $output, %opts) {
    Office::_decode("sheet_cast",
        office__sheet_cast(to_json({ path => $path, output => $output, by => $opts{by}, type => $opts{type}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Strip whitespace from every string cell (whole-sheet trim). opts: collapse
## (collapse internal whitespace to single spaces), output (default in place),
## sheet, header, format. Returns { ok, path, trimmed }.
fn Office::sheet_strip ($path, %opts) {
    Office::_decode("sheet_strip",
        office__sheet_strip(to_json({ path => $path, collapse => $opts{collapse}, output => $opts{output}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Pad a column's values to a fixed $width with a fill string (e.g. zero-pad IDs).
## opts: fill (default "0"), side (left|right, default left), into (new column;
## default in place), sheet, header, format. Returns { ok, path, padded }.
fn Office::sheet_pad ($path, $output, $column, $width, %opts) {
    Office::_decode("sheet_pad",
        office__sheet_pad(to_json({ path => $path, output => $output, column => $column, width => $width, fill => $opts{fill}, side => $opts{side}, into => $opts{into}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Reverse the order of a sheet's data rows (header kept on top). opts: output
## (default in place), sheet, header, format. Returns { ok, path, rows }.
fn Office::sheet_reverse ($path, %opts) {
    Office::_decode("sheet_reverse",
        office__sheet_reverse(to_json({ path => $path, output => $opts{output}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Append a column with the first non-blank value across $columns (SQL COALESCE).
## opts: into (default "coalesce"), default (when all blank), sheet, header,
## format. Returns { ok, path, column, filled }.
fn Office::sheet_coalesce ($path, $output, $columns, %opts) {
    Office::_decode("sheet_coalesce",
        office__sheet_coalesce(to_json({ path => $path, output => $output, columns => $columns, into => $opts{into}, default => $opts{default}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Recode a column's values via a $map of { old => new } (pandas Series.map).
## opts: default (for unmapped; omit to keep original), into (new column; default
## in place), sheet, header, format. Returns { ok, path, recoded }.
fn Office::sheet_recode ($path, $output, $column, $map, %opts) {
    Office::_decode("sheet_recode",
        office__sheet_recode(to_json({ path => $path, output => $output, column => $column, map => $map, default => $opts{default}, into => $opts{into}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Split a sheet's rows into fixed-size chunks of $size data rows, written to
## $dir as {prefix}-{n}.{ext}. opts: header => 0 to not repeat the header in
## each chunk, sheet, format => output extension (default: source's), prefix.
## Returns { count, files }.
fn Office::sheet_chunk ($path, $size, $dir, %opts) {
    Office::_decode("sheet_chunk",
        office__sheet_chunk(to_json({ path => $path, size => $size, dir => $dir, header => $opts{header}, sheet => $opts{sheet}, format => $opts{format}, prefix => $opts{prefix} })))
}

## Explode a multi-sheet workbook into one file per sheet, written to $dir as
## {prefix}{sheet}.{ext}. opts: format => output extension (default: the
## source's), prefix => filename prefix. Returns { count, files }.
fn Office::sheet_split ($path, $dir, %opts) {
    Office::_decode("sheet_split",
        office__sheet_split(to_json({ path => $path, dir => $dir, format => $opts{format}, prefix => $opts{prefix} })))
}

## Fill blank cells. opts: method => "ffill" (default; carry the last non-blank
## value down) | "value" (use a constant value => ...), by => column name/index
## or arrayref (default: all columns), sheet, output (default: in place),
## header => 0 if first row is data, format. Returns { ok, path, filled }.
fn Office::sheet_fill ($path, %opts) {
    Office::_decode("sheet_fill",
        office__sheet_fill(to_json({ path => $path, method => $opts{method}, value => $opts{value}, by => $opts{by}, output => $opts{output}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Fill internal blank cells in numeric column(s) by linear interpolation between
## known neighbors (pandas Series.interpolate). opts: by (column(s); default all),
## decimals, output (default in place), sheet, header, format. Leading/trailing
## gaps stay blank. Returns { ok, path, filled }.
fn Office::sheet_interpolate ($path, %opts) {
    Office::_decode("sheet_interpolate",
        office__sheet_interpolate(to_json({ path => $path, by => $opts{by}, decimals => $opts{decimals}, output => $opts{output}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Drop fully-empty rows and/or columns. opts: rows (default 1), cols (default
## 0), output, sheet, header, format. Returns { ok, path, rows_removed, cols_removed }.
fn Office::sheet_drop_empty ($path, $output, %opts) {
    Office::_decode("sheet_drop_empty",
        office__sheet_drop_empty(to_json({ path => $path, output => $output, rows => $opts{rows}, cols => $opts{cols}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Prepend a header row of $names (for headerless data). opts: sheet, format.
## Returns { ok, path, columns }.
fn Office::sheet_add_header ($path, $names, $output, %opts) {
    Office::_decode("sheet_add_header",
        office__sheet_add_header(to_json({ path => $path, names => $names, output => $output, sheet => $opts{sheet}, format => $opts{format} })))
}

## Append a computed column from an arithmetic op (+ - * / %) between two columns
## or a column and a constant. opts: right (column) or value (constant), into,
## decimals, sheet, header, format. Returns { ok, path, column }.
fn Office::sheet_calc ($path, $left, $op, $output, %opts) {
    Office::_decode("sheet_calc",
        office__sheet_calc(to_json({ path => $path, left => $left, op => $op, output => $output, right => $opts{right}, value => $opts{value}, into => $opts{into}, decimals => $opts{decimals}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Filter rows by multiple $conditions ([{ column, op?, value, ignore_case? }]).
## opts: match (all/any), sheet, header, format. Returns { ok, path, kept }.
fn Office::sheet_where ($path, $conditions, $output, %opts) {
    Office::_decode("sheet_where",
        office__sheet_where(to_json({ path => $path, conditions => $conditions, output => $output, match => $opts{match}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Freeze panes on a sheet (xlsx). opts: row (default 1), col (default 0),
## output, sheet, format. Returns { ok, path, row, col }.
fn Office::sheet_freeze ($path, $output, %opts) {
    Office::_decode("sheet_freeze",
        office__sheet_freeze(to_json({ path => $path, output => $output, row => $opts{row}, col => $opts{col}, sheet => $opts{sheet}, format => $opts{format} })))
}

## Apply an autofilter over a sheet's range (xlsx). opts: range ([r1,c1,r2,c2],
## default whole used range), sheet, format. Returns { ok, path, range }.
fn Office::sheet_autofilter ($path, $output, %opts) {
    Office::_decode("sheet_autofilter",
        office__sheet_autofilter(to_json({ path => $path, output => $output, range => $opts{range}, sheet => $opts{sheet}, format => $opts{format} })))
}

## Auto-size columns to their content (xlsx). opts: sheet (default all), output
## (default in place), format. Returns { ok, path, sheets }.
fn Office::sheet_autosize ($path, %opts) {
    Office::_decode("sheet_autosize",
        office__sheet_autosize(to_json({ path => $path, sheet => $opts{sheet}, output => $opts{output}, format => $opts{format} })))
}

## Enable worksheet protection (xlsx). opts: password (omit for password-less),
## sheet (default all), output (default in place), format. Returns
## { ok, path, sheets }.
fn Office::sheet_protect ($path, %opts) {
    Office::_decode("sheet_protect",
        office__sheet_protect(to_json({ path => $path, password => $opts{password}, sheet => $opts{sheet}, output => $opts{output}, format => $opts{format} })))
}

## Extract cell comments / notes from an xlsx. Returns
## { comments => [{ cell, author, text }], count }.
fn Office::sheet_comments ($path) {
    Office::_decode("sheet_comments", office__sheet_comments(to_json({ path => $path })))
}

## Round every numeric cell (or selected columns) to N decimals. opts: decimals
## (default 2), columns, sheet, header, format. Returns { ok, path, rounded }.
fn Office::sheet_round ($path, $output, %opts) {
    Office::_decode("sheet_round",
        office__sheet_round(to_json({ path => $path, output => $output, decimals => $opts{decimals}, columns => $opts{columns}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Histogram of a numeric column into equal-width bins. opts: bins (default 10),
## sheet, header. Returns { column, count, min, max, bins: [{lo, hi, count}] }.
fn Office::sheet_histogram ($path, $column, %opts) {
    Office::_decode("sheet_histogram",
        office__sheet_histogram(to_json({ path => $path, column => $column, bins => $opts{bins}, sheet => $opts{sheet}, header => $opts{header} })))
}

## Bucket a numeric column and append the bin assignment as a new column
## (pandas pd.cut). opts: edges (ascending boundary array) OR bins (default 10),
## labels (per-bin names), into (default "{column}_bin"), sheet, header, format.
## Returns { ok, path, column, into, bins }.
fn Office::sheet_bin ($path, $output, $column, %opts) {
    Office::_decode("sheet_bin",
        office__sheet_bin(to_json({ path => $path, output => $output, column => $column, edges => $opts{edges}, bins => $opts{bins}, labels => $opts{labels}, into => $opts{into}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Append an equal-frequency bucket column (SQL NTILE / pandas qcut). opts: n
## (bucket count, default 4 = quartiles), labels (length-n names), into (default
## "{column}_ntile"), sheet, header, format. Returns { ok, path, column, into, buckets }.
fn Office::sheet_ntile ($path, $output, $column, %opts) {
    Office::_decode("sheet_ntile",
        office__sheet_ntile(to_json({ path => $path, output => $output, column => $column, n => $opts{n}, labels => $opts{labels}, into => $opts{into}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Detect outlier rows in a numeric column. opts: method (iqr default | zscore),
## k (iqr fence 1.5 / zscore threshold 3), sheet, header. Returns
## { column, method, count, lower, upper, outliers: [{row, value}] }.
fn Office::sheet_outliers ($path, $column, %opts) {
    Office::_decode("sheet_outliers",
        office__sheet_outliers(to_json({ path => $path, column => $column, method => $opts{method}, k => $opts{k}, sheet => $opts{sheet}, header => $opts{header} })))
}

## Sample covariance matrix over a sheet's numeric columns (diagonal = sample
## variance). opts: sheet, header. Returns { sheet, columns, matrix }.
fn Office::sheet_cov ($path, %opts) {
    Office::_decode("sheet_cov",
        office__sheet_cov(to_json({ path => $path, sheet => $opts{sheet}, header => $opts{header} })))
}

## Remove duplicate data rows (SQL DISTINCT). opts: by => a column name/index or
## arrayref of them (default: whole row), keep => "first" (default) | "last",
## sheet, header => 0 if first row is data, format => override. Returns
## { ok, path, kept, removed }.
fn Office::sheet_dedupe ($path, $output, %opts) {
    Office::_decode("sheet_dedupe",
        office__sheet_dedupe(to_json({ path => $path, output => $output, by => $opts{by}, keep => $opts{keep}, sheet => $opts{sheet}, header => $opts{header}, format => $opts{format} })))
}

## Find/report duplicate rows by key (data-quality audit; counterpart to dedupe).
## opts: by (key column(s); default whole row), sheet, header. Returns
## { duplicates, groups => [{ key, count, rows }] }.
fn Office::sheet_duplicates ($path, %opts) {
    Office::_decode("sheet_duplicates",
        office__sheet_duplicates(to_json({ path => $path, by => $opts{by}, sheet => $opts{sheet}, header => $opts{header} })))
}

# ── documents ───────────────────────────────────────────────────────

## Read a word-processing document (docx/odt). Returns a list of paragraph
## strings.
fn Office::doc_read ($path) {
    val $o = Office::_decode("doc_read", office__doc_read(to_json({ path => $path })))
    @{ $o->{paragraphs} }
}

## Extract every table from a docx/odt as row-major string grids. Returns
## { tables => [{ rows => [[cell, ...], ...] }, ...], count }. The read-side
## mirror of doc_write's "table" block.
fn Office::doc_tables ($path) {
    Office::_decode("doc_tables", office__doc_tables(to_json({ path => $path })))
}

## Extract one table from a docx/odt into a spreadsheet file (xlsx/ods/csv).
## opts: index (0-based, default 0), name, format. Returns { ok, path, rows, cols }.
fn Office::doc_table_to_sheet ($path, $output, %opts) {
    Office::_decode("doc_table_to_sheet",
        office__doc_table_to_sheet(to_json({ path => $path, output => $output, index => $opts{index}, name => $opts{name}, format => $opts{format} })))
}

## Render a spreadsheet as a table inside a docx/odt (inverse of
## doc_table_to_sheet). opts: sheet, title, format. Returns { ok, path, rows, cols }.
fn Office::sheet_to_doc ($path, $output, %opts) {
    Office::_decode("sheet_to_doc",
        office__sheet_to_doc(to_json({ path => $path, output => $output, sheet => $opts{sheet}, title => $opts{title}, format => $opts{format} })))
}

## Heading outline of a docx/odt: returns { outline => [{ level, text }], count }
## in document order — the document analogue of pdf_outline.
fn Office::doc_outline ($path) {
    Office::_decode("doc_outline", office__doc_outline(to_json({ path => $path })))
}

## Ordered structural read of a docx/odt: returns { blocks => [...], count }
## with blocks { kind => "heading", level, text } | { kind => "para", text } |
## { kind => "table", rows => [[cell, ...]] } in document order — the read-side
## mirror of the doc_write block model.
fn Office::doc_blocks ($path) {
    Office::_decode("doc_blocks", office__doc_blocks(to_json({ path => $path })))
}

## Extract every hyperlink from a docx/odt. Returns { links => [{ text, url }],
## count }. docx URLs are resolved through document.xml.rels; internal links
## come back as "#anchor".
fn Office::doc_links ($path) {
    Office::_decode("doc_links", office__doc_links(to_json({ path => $path })))
}

## Extract review comments from a docx (word/comments.xml). Returns
## { comments => [{ id, author, date, initials, text }], count }.
fn Office::doc_comments ($path) {
    Office::_decode("doc_comments", office__doc_comments(to_json({ path => $path })))
}

## Extract footnotes from a docx (word/footnotes.xml). opts: endnotes => 1 to
## read endnotes instead. Returns { notes => [{ id, text }], count }.
fn Office::doc_footnotes ($path, %opts) {
    Office::_decode("doc_footnotes",
        office__doc_footnotes(to_json({ path => $path, endnotes => $opts{endnotes} })))
}

## Word-count statistics for any readable document (docx/odt/html/md/rtf/txt/
## pdf). Returns { words, characters, characters_no_spaces, lines, paragraphs,
## pages? } — pages only for pdf. Mirrors Word's "Word Count".
fn Office::doc_stats ($path) {
    Office::_decode("doc_stats", office__doc_stats(to_json({ path => $path })))
}

## Convert an HTML file into a document, preserving headings, paragraphs, lists,
## and tables. $output's extension picks the format (docx/odt/pdf/md/...). opts:
## format => override. Returns { ok, path, blocks }.
fn Office::html_to_doc ($input, $output, %opts) {
    Office::_decode("html_to_doc",
        office__html_to_doc(to_json({ input => $input, output => $output, format => $opts{format} })))
}

## Parse an HTML table into a spreadsheet (inverse of sheet_to_html). opts:
## index (0-based table), name, format. Returns { ok, path, rows, cols }.
fn Office::html_to_sheet ($input, $output, %opts) {
    Office::_decode("html_to_sheet",
        office__html_to_sheet(to_json({ input => $input, output => $output, index => $opts{index}, name => $opts{name}, format => $opts{format} })))
}

## Convert a Markdown file into a document, preserving headings, bullet/ordered
## lists, and pipe tables. $output's extension picks the format (docx/odt/pdf/
## html/...). opts: format => override. Returns { ok, path, blocks }.
fn Office::md_to_doc ($input, $output, %opts) {
    Office::_decode("md_to_doc",
        office__md_to_doc(to_json({ input => $input, output => $output, format => $opts{format} })))
}

## Convert a docx/odt to structured Markdown (headings + tables preserved),
## written to $output. The inverse of md_to_doc. Returns { ok, path, blocks }.
fn Office::doc_to_md ($path, $output) {
    Office::_decode("doc_to_md",
        office__doc_to_md(to_json({ path => $path, output => $output })))
}

## Convert a docx/odt to structured HTML (headings + tables preserved), written
## to $output. The inverse of html_to_doc. Returns { ok, path, blocks }.
fn Office::doc_to_html ($path, $output) {
    Office::_decode("doc_to_html",
        office__doc_to_html(to_json({ path => $path, output => $output })))
}

## Extract any readable document's plain text to a file (docx/odt/html/md/rtf/
## txt/pdf). Returns { ok, path, chars }.
fn Office::doc_to_text ($path, $output) {
    Office::_decode("doc_to_text",
        office__doc_to_text(to_json({ path => $path, output => $output })))
}

## Convert a PDF's text into a docx/odt (or md/html/txt) document, one paragraph
## per non-blank line with page breaks between pages. opts: format. Returns
## { ok, path, pages, paragraphs }.
fn Office::pdf_to_doc ($path, $output, %opts) {
    Office::_decode("pdf_to_doc",
        office__pdf_to_doc(to_json({ path => $path, output => $output, format => $opts{format} })))
}

## Convert a PDF into a deck, one slide per page (first line -> title, rest ->
## body). opts: format. Returns { ok, path, slides }.
fn Office::pdf_to_slides ($path, $output, %opts) {
    Office::_decode("pdf_to_slides",
        office__pdf_to_slides(to_json({ path => $path, output => $output, format => $opts{format} })))
}

## Render a docx/odt document to a PDF (headings/paras/lists/tables/page-breaks).
## Returns { ok, path, elements }.
fn Office::doc_to_pdf ($path, $output) {
    Office::_decode("doc_to_pdf",
        office__doc_to_pdf(to_json({ path => $path, output => $output })))
}

## Render an HTML file straight to a PDF (html_to_doc + doc_to_pdf in one).
## Returns { ok, path, elements }.
fn Office::html_to_pdf ($input, $output) {
    Office::_decode("html_to_pdf",
        office__html_to_pdf(to_json({ input => $input, output => $output })))
}

## Render a Markdown file straight to a PDF (md_to_doc + doc_to_pdf in one).
## Returns { ok, path, elements }.
fn Office::md_to_pdf ($input, $output) {
    Office::_decode("md_to_pdf",
        office__md_to_pdf(to_json({ input => $input, output => $output })))
}

## Generate a Table of Contents from a document's headings and prepend it.
## opts: output, title, pagebreak, format. Returns { ok, path, entries }.
fn Office::doc_add_toc ($path, %opts) {
    Office::_decode("doc_add_toc",
        office__doc_add_toc(to_json({ path => $path, output => $opts{output}, title => $opts{title}, pagebreak => $opts{pagebreak}, format => $opts{format} })))
}

## Convert a document into a presentation: each heading at $opts{level} (default
## 1) becomes a slide title, following content becomes body bullets. $output is
## a pptx/odp path. opts: level, format => override. Returns { ok, path, slides }.
fn Office::doc_to_slides ($path, $output, %opts) {
    Office::_decode("doc_to_slides",
        office__doc_to_slides(to_json({ path => $path, output => $output, level => $opts{level}, format => $opts{format} })))
}

## Convert a presentation into a document: each slide's first line becomes a
## heading, the rest paragraphs. $output is a docx/odt/pdf/md/html path. opts:
## notes => 1 to append speaker notes, format => override. The inverse of
## doc_to_slides. Returns { ok, path, slides }.
fn Office::slides_to_doc ($path, $output, %opts) {
    Office::_decode("slides_to_doc",
        office__slides_to_doc(to_json({ path => $path, output => $output, notes => $opts{notes}, format => $opts{format} })))
}

## Render a presentation to a PDF handout — one slide per page (title heading +
## body paragraphs). $output is a pdf path. opts: notes => 1 to append speaker
## notes. Returns { ok, path, slides }.
fn Office::slides_to_pdf ($path, $output, %opts) {
    Office::_decode("slides_to_pdf",
        office__slides_to_pdf(to_json({ path => $path, output => $output, notes => $opts{notes} })))
}

fn Office::slides_outline ($path) {
    Office::_decode("slides_outline",
        office__slides_outline(to_json({ path => $path })))
}

## Render a presentation as a Markdown outline (titles -> headings, body ->
## bullets). opts: output, level, notes. Returns { ok, slides, markdown, path? }.
fn Office::slides_to_md ($path, %opts) {
    Office::_decode("slides_to_md",
        office__slides_to_md(to_json({ path => $path, output => $opts{output}, level => $opts{level}, notes => $opts{notes} })))
}

## Render a presentation as an HTML page (one <section> per slide, title in <h2>,
## body as <ul>). opts: output, notes, full. Returns { ok, slides, html, path? }.
fn Office::slides_to_html ($path, %opts) {
    Office::_decode("slides_to_html",
        office__slides_to_html(to_json({ path => $path, output => $opts{output}, notes => $opts{notes}, full => $opts{full} })))
}

## Extract a presentation's text as plain text, slide by slide. opts: output,
## notes, sep. Returns { ok, slides, text, path? }.
fn Office::slides_to_text ($path, %opts) {
    Office::_decode("slides_to_text",
        office__slides_to_text(to_json({ path => $path, output => $opts{output}, notes => $opts{notes}, sep => $opts{sep} })))
}

## Extract a deck into a spreadsheet (one row per slide: number, title, text).
## Reverse of sheet_to_slides. opts: sep, format. Returns { ok, path, slides }.
fn Office::slides_to_sheet ($path, $output, %opts) {
    Office::_decode("slides_to_sheet",
        office__slides_to_sheet(to_json({ path => $path, output => $output, sep => $opts{sep}, format => $opts{format} })))
}

## Extract a PDF's text into a spreadsheet (one row per non-blank line: page,
## text). opts: format. Returns { ok, path, rows }.
fn Office::pdf_to_sheet ($path, $output, %opts) {
    Office::_decode("pdf_to_sheet",
        office__pdf_to_sheet(to_json({ path => $path, output => $output, format => $opts{format} })))
}

## Extract a document into a spreadsheet (one row per block: level, text).
## opts: format. Returns { ok, path, rows }.
fn Office::doc_to_sheet ($path, $output, %opts) {
    Office::_decode("doc_to_sheet",
        office__doc_to_sheet(to_json({ path => $path, output => $output, format => $opts{format} })))
}

## Parse a Markdown outline into a presentation (inverse of slides_to_md).
## opts: markdown (text) or path (.md file), format. Returns { ok, path, slides }.
fn Office::md_to_slides ($output, %opts) {
    Office::_decode("md_to_slides",
        office__md_to_slides(to_json({ output => $output, markdown => $opts{markdown}, path => $opts{path}, format => $opts{format} })))
}

## Split a document into multiple files at headings of a given level, written to
## $dir as {prefix}-{n}.{ext}. opts: level => heading level to split at (default
## 1), format => output extension (default: the source's), prefix => filename
## stem (default: the source's). Returns { count, files }.
fn Office::doc_split ($path, $dir, %opts) {
    Office::_decode("doc_split",
        office__doc_split(to_json({ path => $path, dir => $dir, level => $opts{level}, format => $opts{format}, prefix => $opts{prefix} })))
}

## Append blocks to an existing document. $blocks is an arrayref of doc_write
## blocks. opts: output (default: in place), page_break => 1 to break before the
## appended content, format => override. Returns { ok, path, blocks, added }.
fn Office::doc_append ($path, $blocks, %opts) {
    Office::_decode("doc_append",
        office__doc_append(to_json({ path => $path, blocks => $blocks, output => $opts{output}, page_break => $opts{page_break}, format => $opts{format} })))
}

## Word-frequency analysis for any readable document (docx/odt/html/md/rtf/txt/
## pdf). opts: top => N (default 20), min_length => N (default 1), ignore_case
## => 0, stopwords => 1 (filter common English words). Returns { total, unique,
## words => [{ word, count }] } sorted by count desc.
fn Office::doc_wordfreq ($path, %opts) {
    Office::_decode("doc_wordfreq",
        office__doc_wordfreq(to_json({ path => $path, top => $opts{top}, min_length => $opts{min_length}, ignore_case => $opts{ignore_case}, stopwords => $opts{stopwords} })))
}

## Readability scores for any readable document (docx/odt/html/md/rtf/txt/pdf):
## Flesch Reading Ease + Flesch–Kincaid Grade Level. Returns { words, sentences,
## syllables, flesch_reading_ease, flesch_kincaid_grade }.
fn Office::doc_readability ($path) {
    Office::_decode("doc_readability",
        office__doc_readability(to_json({ path => $path })))
}

## Search a document's paragraphs (docx/odt/html/md/rtf/txt/pdf). opts:
## ignore_case => 1. Returns { count, matches => [{ paragraph, count, snippet }] }
## with 1-based paragraph indexes.
fn Office::doc_find ($path, $query, %opts) {
    Office::_decode("doc_find",
        office__doc_find(to_json({ path => $path, query => $query, ignore_case => $opts{ignore_case} })))
}

## Search a presentation's slide text and speaker notes (pptx/odp). opts:
## ignore_case => 1. Returns { count, matches => [{ slide, where, value }] } —
## where is "text" or "notes", slide is 1-based.
fn Office::slides_find ($path, $query, %opts) {
    Office::_decode("slides_find",
        office__slides_find(to_json({ path => $path, query => $query, ignore_case => $opts{ignore_case} })))
}

## Concatenate documents into one. $inputs is an arrayref of paths; the target
## format comes from $output's extension (so this also converts). opts:
## page_breaks => 0 to omit the break between sources (default on),
## format => override. Returns { ok, path, sources, blocks }.
fn Office::doc_merge ($inputs, $output, %opts) {
    Office::_decode("doc_merge",
        office__doc_merge(to_json({ inputs => $inputs, output => $output, page_breaks => $opts{page_breaks}, format => $opts{format} })))
}

## Compare two documents paragraph-by-paragraph (order-aware LCS diff). Returns
## { same, added, removed, added_paragraphs, removed_paragraphs }.
fn Office::doc_diff ($a, $b) {
    Office::_decode("doc_diff",
        office__doc_diff(to_json({ a => $a, b => $b })))
}

## Write a document. $blocks is an arrayref of blocks:
##   { kind => "para"|"heading", level, align, text }  (or runs => [{text, bold, ...}])
##   { kind => "list", ordered => 1|0, items => [str, ...] }   # numbered/bulleted (docx)
##   { kind => "link", url => "...", text => "..." }            # hyperlink (docx)
##   { kind => "table", rows => [[cell, ...]] }   # cell may be a styled object
##       { text|runs, align, bg, span, width (dxa), valign } (docx)
##   { kind => "image", path => "...", width, height }   # px (docx)
##   { kind => "pagebreak" }
## opts: format => "docx"|"odt"|"html"|"md"|"rtf"|"txt"|"pdf",
## page_size => [w, h] (twips, docx), header => "...", footer => "..." (docx).
fn Office::doc_write ($path, $blocks, %opts) {
    val $r = { path => $path, blocks => $blocks, format => $opts{format}, page_size => $opts{page_size}, header => $opts{header}, footer => $opts{footer}, page_numbers => $opts{page_numbers} }
    Office::_decode("doc_write", office__doc_write(to_json($r)))
}

# ── presentations ───────────────────────────────────────────────────

## Read a presentation (pptx/odp). Returns an arrayref of slides, each
## { text => [line, ...] }.
## Read a presentation (pptx/odp). Returns a list of { text => [...],
## notes => [...] } per slide — `notes` holds the speaker notes.
fn Office::slides_read ($path) {
    Office::_decode("slides_read", office__slides_read(to_json({ path => $path })))->{slides}
}

## Write a presentation. $slides is an arrayref of
## { title => "...", body => [line, ...] }.
## opts: format => "pptx"|"odp" (default: from $path extension).
fn Office::slides_write ($path, $slides, %opts) {
    val $r = { path => $path, slides => $slides, format => $opts{format} }
    Office::_decode("slides_write", office__slides_write(to_json($r)))
}

## Insert a picture onto a slide of an existing pptx (deck analogue of
## pdf_stamp_image). opts: output (default in place), slide (1-based, default 1),
## x/y (px, default 96), width/height (px, default native). Returns
## { ok, path, slide, image }.
fn Office::slides_add_image ($path, $image, %opts) {
    Office::_decode("slides_add_image",
        office__slides_add_image(to_json({ path => $path, image => $image, output => $opts{output}, slide => $opts{slide}, x => $opts{x}, y => $opts{y}, width => $opts{width}, height => $opts{height} })))
}

## Set/replace a slide's speaker notes ($notes = string or arrayref of lines).
## opts: slide (1-based, default 1), output (default in place). Returns
## { ok, path, slide, lines }.
fn Office::slides_set_notes ($path, $notes, %opts) {
    Office::_decode("slides_set_notes",
        office__slides_set_notes(to_json({ path => $path, notes => $notes, slide => $opts{slide}, output => $opts{output} })))
}

## Add a text box to a slide of an existing pptx. opts: slide (1-based), x/y (px),
## width/height (px), size (pt), output. Returns { ok, path, slide }.
fn Office::slides_add_text ($path, $text, %opts) {
    Office::_decode("slides_add_text",
        office__slides_add_text(to_json({ path => $path, text => $text, slide => $opts{slide}, x => $opts{x}, y => $opts{y}, width => $opts{width}, height => $opts{height}, size => $opts{size}, output => $opts{output} })))
}

## Concatenate presentations into one deck. $inputs is an arrayref of paths; the
## target format follows $output's extension (so this also converts pptx<->odp).
## Each source slide's first text line becomes the title, the rest the body
## (slide text only — notes/media are not carried). Returns { ok, path, sources,
## slides }.
fn Office::slides_merge ($inputs, $output, %opts) {
    Office::_decode("slides_merge",
        office__slides_merge(to_json({ inputs => $inputs, output => $output, format => $opts{format} })))
}

## Reorder/subset a deck's slides by a 1-based $order list (deck analogue of
## pdf_reorder). opts: output (default in place), format. Returns { ok, path, slides }.
fn Office::slides_reorder ($path, $order, %opts) {
    Office::_decode("slides_reorder",
        office__slides_reorder(to_json({ path => $path, order => $order, output => $opts{output}, format => $opts{format} })))
}

## Delete slides by 1-based number (number or array) — deck analogue of
## pdf_delete. opts: output (default in place), format. Returns
## { ok, path, removed, slides }.
fn Office::slides_delete ($path, $slides, %opts) {
    Office::_decode("slides_delete",
        office__slides_delete(to_json({ path => $path, slides => $slides, output => $opts{output}, format => $opts{format} })))
}

fn Office::slides_split ($path, $dir, %opts) {
    Office::_decode("slides_split",
        office__slides_split(to_json({ path => $path, dir => $dir, format => $opts{format}, prefix => $opts{prefix} })))
}

## Statistics for a presentation (pptx/odp). Returns { slides, words (in slide
## text), notes_words, per_slide => [{ words, notes_words }] }.
fn Office::slides_stats ($path) {
    Office::_decode("slides_stats", office__slides_stats(to_json({ path => $path })))
}

## Append slides to an existing presentation. $slides is an arrayref of
## { title, body => [...] }. opts: output (default: in place), format =>
## override. Returns { ok, path, slides, added }.
fn Office::slides_append ($path, $slides, %opts) {
    Office::_decode("slides_append",
        office__slides_append(to_json({ path => $path, slides => $slides, output => $opts{output}, format => $opts{format} })))
}

## Insert a new slide at a 1-based position (default append). opts: title, body
## (arrayref of lines), position, output (default in place), format. Returns
## { ok, path, position, slides }.
fn Office::slides_insert ($path, %opts) {
    Office::_decode("slides_insert",
        office__slides_insert(to_json({ path => $path, title => $opts{title}, body => $opts{body}, position => $opts{position}, output => $opts{output}, format => $opts{format} })))
}

## Set (replace) the title of slide $slide (1-based); body preserved. opts:
## output (default in place), format. Returns { ok, path, slide }.
fn Office::slides_set_title ($path, $slide, $title, %opts) {
    Office::_decode("slides_set_title",
        office__slides_set_title(to_json({ path => $path, slide => $slide, title => $title, output => $opts{output}, format => $opts{format} })))
}

# ── pdf ─────────────────────────────────────────────────────────────

## Extract text from a PDF. Returns a hashref { pages => [...], text => "..." }.
fn Office::pdf_read ($path) {
    Office::_decode("pdf_read", office__pdf_read(to_json({ path => $path })))
}

## Write a text PDF (A4). $lines is an arrayref of strings, one per line.
fn Office::pdf_write ($path, $lines) {
    die "Office::pdf_write: lines must be arrayref" unless ref($lines) eq "ARRAY"
    Office::_decode("pdf_write", office__pdf_write(to_json({ path => $path, lines => $lines })))
}

## Build a multi-page PDF document from $elements (base-14 fonts, no embed).
## Each element is one of:
##   { type => "heading", text, level? }          # flowing, bold
##   { type => "paragraph", text, size?, font?, color? }   # auto-wrapped
##   { type => "text", x, y, text, size?, font?, color? }  # absolute (top-left)
##   { type => "image", path|handle, x?, y?, width?, height? }  # JPEG embed
##   { type => "rect", x, y, width, height, color?, fill? }
##   { type => "line", x0, y0, x1, y1, color? }
##   { type => "pagebreak" }
## opts: page_size => [w, h] (points, default A4 595x842), margin (default 50).
## Fonts: "helvetica" (default), "bold", "times", "courier".
fn Office::pdf_build ($path, $elements, %opts) {
    Office::_decode("pdf_build",
        office__pdf_build(to_json({ path => $path, elements => $elements, page_size => $opts{page_size}, margin => $opts{margin} })))
}

## Build a PDF from image files — one image per page, each scaled to fit the
## page within the margins (aspect preserved). $images is an arrayref of paths.
## opts: page_size => [w, h] points (default A4), margin => points (default 36).
## Returns { ok, path, pages }.
fn Office::images_to_pdf ($images, $output, %opts) {
    Office::_decode("images_to_pdf",
        office__images_to_pdf(to_json({ images => $images, output => $output, page_size => $opts{page_size}, margin => $opts{margin} })))
}

## Render a spreadsheet as a bordered table in a PDF. opts: sheet => name/index,
## title => optional heading, header => 0 to not shade/bold the first row,
## size => font points, landscape => 1, margin. Returns { ok, path, pages,
## bytes }. (pdf_build also accepts a { type => "table", rows => [[...]] } element
## directly for tables inside larger documents.)
fn Office::sheet_to_pdf ($path, $output, %opts) {
    Office::_decode("sheet_to_pdf",
        office__sheet_to_pdf(to_json({ path => $path, output => $output, sheet => $opts{sheet}, title => $opts{title}, header => $opts{header}, size => $opts{size}, landscape => $opts{landscape}, margin => $opts{margin} })))
}

## Merge several PDFs into one (page order = $inputs order). Returns
## { pages, merged }.
fn Office::pdf_merge ($inputs, $path) {
    die "Office::pdf_merge: inputs must be arrayref" unless ref($inputs) eq "ARRAY"
    Office::_decode("pdf_merge", office__pdf_merge(to_json({ inputs => $inputs, path => $path })))
}

## Generate a blank PDF with N empty pages. opts: pages (default 1), size
## (a4|letter|legal|a3|a5, default a4), width/height (points; override size).
## Returns { ok, path, pages, width, height }.
fn Office::pdf_blank ($output, %opts) {
    Office::_decode("pdf_blank",
        office__pdf_blank(to_json({ output => $output, pages => $opts{pages}, size => $opts{size}, width => $opts{width}, height => $opts{height} })))
}

## Extract a subset of pages (1-based, original order) into a new PDF.
fn Office::pdf_split ($path, $pages, $output) {
    die "Office::pdf_split: pages must be arrayref" unless ref($pages) eq "ARRAY"
    Office::_decode("pdf_split", office__pdf_split(to_json({ path => $path, pages => $pages, output => $output })))
}

## Rotate pages by $angle degrees (multiple of 90). opts: pages => [1-based
## subset] (default all).
fn Office::pdf_rotate ($path, $angle, $output, %opts) {
    Office::_decode("pdf_rotate",
        office__pdf_rotate(to_json({ path => $path, angle => $angle, output => $output, pages => $opts{pages} })))
}

## PDF metadata: { pages, version, title?, author?, subject?, creator?,
## producer?, keywords? }.
fn Office::pdf_info ($path) {
    Office::_decode("pdf_info", office__pdf_info(to_json({ path => $path })))
}

## Per-page dimensions of a PDF in points. Returns { pages => [{ page, width,
## height }], count }.
fn Office::pdf_page_sizes ($path) {
    Office::_decode("pdf_page_sizes", office__pdf_page_sizes(to_json({ path => $path })))
}

## Stamp a rotated text watermark on every page. opts: size (60), color
## (light gray), angle (deg, 45).
fn Office::pdf_watermark ($path, $text, $output, %opts) {
    Office::_decode("pdf_watermark",
        office__pdf_watermark(to_json({ path => $path, text => $text, output => $output, size => $opts{size}, color => $opts{color}, angle => $opts{angle} })))
}

## Add footer page numbers to every page. opts: format ("{n} / {total}"),
## size (10), color (black), y (24).
fn Office::pdf_page_numbers ($path, $output, %opts) {
    Office::_decode("pdf_page_numbers",
        office__pdf_page_numbers(to_json({ path => $path, output => $output, format => $opts{format}, size => $opts{size}, color => $opts{color}, y => $opts{y} })))
}

## Password-protect a PDF (standard security handler). opts: owner_password
## (""), user_password (""), aes => 1 (AES-128; default RC4-128),
## key_length (RC4 bits, default 128), permissions => [print, modify, copy,
## annotate, fill, accessibility, assemble, print_hq] (default: all granted).
## Returns { ok, path, method }.
fn Office::pdf_encrypt ($path, $output, %opts) {
    Office::_decode("pdf_encrypt",
        office__pdf_encrypt(to_json({ path => $path, output => $output, owner_password => $opts{owner_password}, user_password => $opts{user_password}, aes => $opts{aes}, key_length => $opts{key_length}, permissions => $opts{permissions} })))
}

## Remove password protection from a PDF. opts: password (owner or user; "").
## Returns { ok, path }.
fn Office::pdf_decrypt ($path, $output, %opts) {
    Office::_decode("pdf_decrypt",
        office__pdf_decrypt(to_json({ path => $path, output => $output, password => $opts{password} })))
}

## Shrink a PDF (prune unreferenced objects + deflate content into object
## streams). Returns { ok, path, before, after, saved } byte counts.
fn Office::pdf_compress ($path, $output) {
    Office::_decode("pdf_compress",
        office__pdf_compress(to_json({ path => $path, output => $output })))
}

## Search a PDF's text page by page. opts: ignore_case => 1. Returns
## { count, matched_pages, pages => [{ page, count, snippet }] } — count is the
## total number of occurrences; page numbers are 1-based.
fn Office::pdf_search ($path, $query, %opts) {
    Office::_decode("pdf_search",
        office__pdf_search(to_json({ path => $path, query => $query, ignore_case => $opts{ignore_case} })))
}

## Set the crop box (visible region) on pages. Pass either box => [x0,y0,x1,y1]
## (points, applied to all selected pages) or margins => [left,bottom,right,top]
## (inset from each page's MediaBox). opts: pages => [1-based subset] (default
## all). Returns { ok, path, cropped }.
fn Office::pdf_crop ($path, $output, %opts) {
    Office::_decode("pdf_crop",
        office__pdf_crop(to_json({ path => $path, output => $output, box => $opts{box}, margins => $opts{margins}, pages => $opts{pages} })))
}

## Split a PDF into one file per page, written to $dir as {prefix}-{n}.pdf.
## opts: prefix => filename stem (default: the source's stem). Returns
## { count, files }.
fn Office::pdf_burst ($path, $dir, %opts) {
    Office::_decode("pdf_burst",
        office__pdf_burst(to_json({ path => $path, dir => $dir, prefix => $opts{prefix} })))
}

## Draw lines on PDF pages (dividers, underlines, signature lines). $lines is an
## arrayref of [x0, y0, x1, y1] (points, y from bottom). opts: color (default
## black), width (default 1), pages => [1-based subset] (default all). Returns
## { ok, path, pages, lines }.
fn Office::pdf_draw_line ($path, $lines, $output, %opts) {
    Office::_decode("pdf_draw_line",
        office__pdf_draw_line(to_json({ path => $path, lines => $lines, output => $output, color => $opts{color}, width => $opts{width}, pages => $opts{pages} })))
}

## Add a clickable URI link annotation to a PDF page. opts: output, page
## (1-based), rect ([x0,y0,x1,y1], default whole page). Returns { ok, path, page }.
fn Office::pdf_add_link ($path, $url, %opts) {
    Office::_decode("pdf_add_link",
        office__pdf_add_link(to_json({ path => $path, url => $url, output => $opts{output}, page => $opts{page}, rect => $opts{rect} })))
}

## Extract every URI link annotation from a PDF (analogue of doc_links).
## Returns { links => [{ page, url, rect }], count }.
fn Office::pdf_links ($path) {
    Office::_decode("pdf_links", office__pdf_links(to_json({ path => $path })))
}

## Strip annotations from a PDF to sanitize before sharing. opts: output,
## subtype (remove only this /Subtype; omit = all). Returns { ok, path, removed }.
fn Office::pdf_remove_annotations ($path, %opts) {
    Office::_decode("pdf_remove_annotations",
        office__pdf_remove_annotations(to_json({ path => $path, output => $opts{output}, subtype => $opts{subtype} })))
}

## Add a highlight annotation over a rectangle. opts: page (1-based), color
## ([r,g,b] 0-255), opacity, output. Returns { ok, path, page }.
fn Office::pdf_highlight ($path, $rect, %opts) {
    Office::_decode("pdf_highlight",
        office__pdf_highlight(to_json({ path => $path, rect => $rect, page => $opts{page}, color => $opts{color}, opacity => $opts{opacity}, output => $opts{output} })))
}

## List every annotation in a PDF (highlights, comments, links, ...).
## Returns { annotations => [{ page, subtype, rect, contents?, uri? }], count }.
fn Office::pdf_annotations ($path) {
    Office::_decode("pdf_annotations", office__pdf_annotations(to_json({ path => $path })))
}

## Add text at a position on PDF pages (labels, stamps, annotations). opts: x/y
## => position in points (default 72,72; y from bottom), size (default 12),
## color (default black), pages => [1-based subset] (default all). Returns
## { ok, path, pages }.
fn Office::pdf_add_text ($path, $text, $output, %opts) {
    Office::_decode("pdf_add_text",
        office__pdf_add_text(to_json({ path => $path, text => $text, output => $output, x => $opts{x}, y => $opts{y}, size => $opts{size}, color => $opts{color}, pages => $opts{pages} })))
}

## Draw rectangles on PDF pages (color blocks, covering regions, highlights).
## $rects is an arrayref of [x, y, w, h] (points, y from bottom). opts: color
## (default black), fill => 0 to stroke instead, pages => [1-based subset]
## (default all). Returns { ok, path, pages, rects }.
fn Office::pdf_draw_rect ($path, $rects, $output, %opts) {
    Office::_decode("pdf_draw_rect",
        office__pdf_draw_rect(to_json({ path => $path, rects => $rects, output => $output, color => $opts{color}, fill => $opts{fill}, pages => $opts{pages} })))
}

## Insert $insert's pages into the $path PDF after a given page. opts: position
## => 1-based page after which to insert (0 = before all, default = end).
## Returns { ok, path, pages }.
fn Office::pdf_insert ($path, $insert, $output, %opts) {
    Office::_decode("pdf_insert",
        office__pdf_insert(to_json({ path => $path, insert => $insert, output => $output, position => $opts{position} })))
}

## Stamp an image (logo/signature/watermark) onto PDF pages. opts: x/y =>
## lower-left position in points (default 36,36), width/height => size in points
## (default: image pixel size), pages => [1-based subset] (default all). Returns
## { ok, path, stamped }.
fn Office::pdf_stamp_image ($path, $image, $output, %opts) {
    Office::_decode("pdf_stamp_image",
        office__pdf_stamp_image(to_json({ path => $path, image => $image, output => $output, x => $opts{x}, y => $opts{y}, width => $opts{width}, height => $opts{height}, pages => $opts{pages} })))
}

## Assemble one PDF from a mix of inputs in order — image files become
## fit-to-page pages, existing PDFs are merged in. $inputs is an arrayref of
## paths. Returns { ok, path, inputs, pages }.
fn Office::pdf_assemble ($inputs, $output) {
    Office::_decode("pdf_assemble",
        office__pdf_assemble(to_json({ inputs => $inputs, output => $output })))
}

## Extract a PDF's text to a file. Pass either dir => write one page-{n}.txt per
## page (returns { count, files }), or output => write the whole text (pages
## joined by opts{separator}, default "\n\n") to one file (returns { ok, path,
## pages, chars }).
fn Office::pdf_to_text ($path, %opts) {
    Office::_decode("pdf_to_text",
        office__pdf_to_text(to_json({ path => $path, output => $opts{output}, dir => $opts{dir}, separator => $opts{separator} })))
}

## Word/character statistics for a PDF (analogue of doc_stats). Returns
## { pages, words, chars, chars_no_spaces, per_page }.
fn Office::pdf_stats ($path) {
    Office::_decode("pdf_stats",
        office__pdf_stats(to_json({ path => $path })))
}

## Split a PDF into one file per page range. $ranges is an arrayref of
## [start, end] pairs (1-based, inclusive), written to $dir as {prefix}-{n}.pdf.
## opts: prefix => filename stem (default: the source's stem). Returns
## { count, files }.
fn Office::pdf_split_ranges ($path, $ranges, $dir, %opts) {
    Office::_decode("pdf_split_ranges",
        office__pdf_split_ranges(to_json({ path => $path, ranges => $ranges, dir => $dir, prefix => $opts{prefix} })))
}

## Split a PDF at its top-level bookmark boundaries (one file per chapter).
## opts: prefix. Returns { count, files }.
fn Office::pdf_split_bookmarks ($path, $dir, %opts) {
    Office::_decode("pdf_split_bookmarks",
        office__pdf_split_bookmarks(to_json({ path => $path, dir => $dir, prefix => $opts{prefix} })))
}

## Split a PDF into fixed-size page chunks of $size pages, written to $dir as
## {prefix}-{n}.pdf (the last chunk may be shorter). opts: prefix => filename
## stem (default: the source's stem). Returns { count, files }.
fn Office::pdf_chunk ($path, $size, $dir, %opts) {
    Office::_decode("pdf_chunk",
        office__pdf_chunk(to_json({ path => $path, size => $size, dir => $dir, prefix => $opts{prefix} })))
}

## Delete pages from a PDF. $pages is an arrayref of 1-based page numbers to
## remove. Returns { ok, path, pages } (remaining count).
fn Office::pdf_delete ($path, $pages, $output) {
    Office::_decode("pdf_delete",
        office__pdf_delete(to_json({ path => $path, pages => $pages, output => $output })))
}

## Reorder (and/or subset) a PDF's pages. $order is an arrayref of 1-based page
## numbers in the desired output order; omitted pages are dropped and a page may
## repeat. Returns { ok, path, pages }.
fn Office::pdf_reorder ($path, $order, $output) {
    Office::_decode("pdf_reorder",
        office__pdf_reorder(to_json({ path => $path, order => $order, output => $output })))
}

## Embed a file inside a PDF (appends to any existing attachments). opts: name
## => stored name (default: the file's basename). Returns { ok, path, name,
## size, count }.
fn Office::pdf_attach ($path, $file, $output, %opts) {
    Office::_decode("pdf_attach",
        office__pdf_attach(to_json({ path => $path, file => $file, output => $output, name => $opts{name} })))
}

## List (and optionally extract) files embedded in a PDF. opts: extract_dir =>
## write each attachment there by basename. Returns { attachments => [{ name,
## size }], count }.
fn Office::pdf_attachments ($path, %opts) {
    Office::_decode("pdf_attachments",
        office__pdf_attachments(to_json({ path => $path, extract_dir => $opts{extract_dir} })))
}

## List the interactive AcroForm fields in a PDF. Returns { fields => [{ name,
## type (text/button/choice/signature), value, options? }], count }.
fn Office::pdf_form_fields ($path) {
    Office::_decode("pdf_form_fields", office__pdf_form_fields(to_json({ path => $path })))
}

## Fill a PDF form. $values is a hashref of { field_name => value }; a checkbox
## takes a boolean (or its explicit on-state name). Sets /NeedAppearances so
## viewers regenerate appearances. opts: output (defaults to $path). Returns
## { ok, path, filled }.
fn Office::pdf_fill_form ($path, $values, %opts) {
    Office::_decode("pdf_fill_form",
        office__pdf_fill_form(to_json({ path => $path, values => $values, output => $opts{output} })))
}

## Read the PDF document outline (bookmarks) as a nested tree. Returns
## { outline => [{ title, page?, children? }], count }.
fn Office::pdf_outline ($path) {
    Office::_decode("pdf_outline", office__pdf_outline(to_json({ path => $path })))
}

## Set the PDF outline (replacing any existing one). $outline is an arrayref of
## { title, page (1-based), bold?, italic?, color? [r,g,b 0..1], children? }
## nodes. opts: output (defaults to $path). Returns { ok, path, count }.
fn Office::pdf_set_outline ($path, $outline, %opts) {
    Office::_decode("pdf_set_outline",
        office__pdf_set_outline(to_json({ path => $path, outline => $outline, output => $opts{output} })))
}

## Read document metadata (core/app properties) from any office or PDF file.
## Returns whichever of these are present: title, author, subject, keywords,
## description, category, last_modified_by, app, producer, company, created,
## modified.
fn Office::meta_read ($path) {
    Office::_decode("meta_read", office__meta_read(to_json({ path => $path })))
}

## Set document metadata, leaving the rest of the file intact. $props is a
## hashref of the canonical keys (see meta_read). opts: output (defaults to
## $path, edit in place). Works for OOXML (xlsx/docx/pptx), ODF, and PDF.
fn Office::meta_write ($path, $props, %opts) {
    Office::_decode("meta_write",
        office__meta_write(to_json({ path => $path, props => $props, output => $opts{output} })))
}

## Extract embedded raster media from an office container (xlsx/docx/pptx,
## ods/odt/odp) or a PDF. Each decoded image is returned as a live image
## handle (use it with any img_* op). opts: dir (also write the originals to
## this directory). Returns { images => [{ name, handle, width, height,
## path? }], count, skipped }.
fn Office::extract_images ($path, %opts) {
    Office::_decode("extract_images",
        office__extract_images(to_json({ path => $path, dir => $opts{dir} })))
}

## Fill a template: search/replace text across a document's run-text parts.
## $replace is a hashref of { find => replacement }. Placeholders split across
## runs (the OOXML norm) are coalesced per paragraph, so `{{name}}` matches
## even when Word stored it as several runs. opts: output (defaults to $path).
## Works on OOXML (docx/pptx/xlsx) and ODF. Returns { ok, path, replaced }.
fn Office::replace_text ($path, $replace, %opts) {
    Office::_decode("replace_text",
        office__replace_text(to_json({ path => $path, replace => $replace, output => $opts{output} })))
}

## Find/replace in a plain-text file (md/html/txt/csv/json/rtf/...). $replace is
## a hashref { find => replacement } (or pass replacements => [{find, replace}]).
## opts: output (default in place), ignore_case => 1 (ASCII). Returns
## { ok, path, replaced }.
fn Office::text_replace ($path, $replace, %opts) {
    Office::_decode("text_replace",
        office__text_replace(to_json({ path => $path, replace => $replace, output => $opts{output}, ignore_case => $opts{ignore_case} })))
}

## Grep matching lines from a text file. opts: ignore_case, invert, max.
## Returns { count, matches => [{ line, text }] } (1-based line numbers).
fn Office::text_grep ($path, $query, %opts) {
    Office::_decode("text_grep",
        office__text_grep(to_json({ path => $path, query => $query, ignore_case => $opts{ignore_case}, invert => $opts{invert}, max => $opts{max} })))
}

## wc-style stats for a raw text file. Returns { lines, words, chars, bytes }.
fn Office::text_stats ($path) {
    Office::_decode("text_stats", office__text_stats(to_json({ path => $path })))
}

## Sort the lines of a text file (sort/uniq). opts: output, descending, numeric,
## unique, ignore_case. Returns { ok, path, lines }.
fn Office::text_sort ($path, %opts) {
    Office::_decode("text_sort",
        office__text_sort(to_json({ path => $path, output => $opts{output}, descending => $opts{descending}, numeric => $opts{numeric}, unique => $opts{unique}, ignore_case => $opts{ignore_case} })))
}

## Collapse duplicate lines (uniq). opts: output, count (prefix run counts),
## global (dedupe non-adjacent too), ignore_case. Returns { ok, path, lines }.
fn Office::text_uniq ($path, %opts) {
    Office::_decode("text_uniq",
        office__text_uniq(to_json({ path => $path, output => $opts{output}, count => $opts{count}, global => $opts{global}, ignore_case => $opts{ignore_case} })))
}

## Extract delimited fields per line (cut -d -f). $fields is an arrayref of
## 1-based field numbers. opts: delim (default tab), output_delim (default delim),
## output. Returns { count, lines, path? }.
fn Office::text_cut ($path, $fields, %opts) {
    Office::_decode("text_cut",
        office__text_cut(to_json({ path => $path, fields => $fields, delim => $opts{delim}, output_delim => $opts{output_delim}, output => $opts{output} })))
}

## Wrap long lines to a max width (fmt/fold -s). opts: width (default 80),
## break_words (hard-split over-long words), output (default in place). Returns
## { ok, path, lines }.
fn Office::text_wrap ($path, %opts) {
    Office::_decode("text_wrap",
        office__text_wrap(to_json({ path => $path, width => $opts{width}, break_words => $opts{break_words}, output => $opts{output} })))
}

## First (or last) N lines of a text file (head/tail). opts: n (default 10),
## tail, output. Returns { count, lines, path? }.
fn Office::text_head ($path, %opts) {
    Office::_decode("text_head",
        office__text_head(to_json({ path => $path, n => $opts{n}, tail => $opts{tail}, output => $opts{output} })))
}

## Mail-merge: fill a {{field}}-placeholder template (docx/pptx/xlsx/odf) once
## per data record, writing one file per record into $dir. opts: data =>
## spreadsheet path (read as records) or records => arrayref of hashes, sheet =>
## source sheet selector, prefix => filename prefix, name_field => field that
## names each file (default: 1-based index). Returns { count, files }.
fn Office::mail_merge ($template, $dir, %opts) {
    Office::_decode("mail_merge",
        office__mail_merge(to_json({ template => $template, dir => $dir, data => $opts{data}, records => $opts{records}, sheet => $opts{sheet}, prefix => $opts{prefix}, name_field => $opts{name_field} })))
}

# ── images (PIL-style I/O + manipulation) ───────────────────────────
#
# Images are handle-based, like a PIL Image object: img_open / img_new
# return an integer handle; later ops take that handle; img_save writes it.
# Colors accept "#rrggbb" / "#rrggbbaa" or [r, g, b] / [r, g, b, a].
# Complements the stryke core `image_*` filter builtins (blur, edge,
# sharpen, grayscale, …) with the file-I/O + manipulation surface.

## Open an image file (png/jpeg/gif/bmp/webp/tiff/…). Returns a hashref
## { handle, width, height, mode }.
fn Office::img_open ($path) {
    Office::_decode("img_open", office__img_open(to_json({ path => $path })))
}

## Create a blank image. opts: color (default opaque black). Returns
## { handle, width, height, mode }.
fn Office::img_new ($width, $height, %opts) {
    Office::_decode("img_new",
        office__img_new(to_json({ width => $width, height => $height, color => $opts{color} })))
}

## Save an image handle to a path; format inferred from the extension.
fn Office::img_save ($handle, $path, %opts) {
    Office::_decode("img_save",
        office__img_save(to_json({ handle => $handle, path => $path, format => $opts{format} })))
}

## Return { handle, width, height, mode } for an open image.
fn Office::img_info ($handle) {
    Office::_decode("img_info", office__img_info(to_json({ handle => $handle })))
}

## Resize to exact dimensions. opts: filter (nearest/triangle/catmullrom/gaussian/lanczos3).
fn Office::img_resize ($handle, $width, $height, %opts) {
    Office::_decode("img_resize",
        office__img_resize(to_json({ handle => $handle, width => $width, height => $height, filter => $opts{filter} })))
}

## Scale down to fit within a $max box, preserving aspect ratio.
fn Office::img_thumbnail ($handle, $max, %opts) {
    Office::_decode("img_thumbnail",
        office__img_thumbnail(to_json({ handle => $handle, max => $max, filter => $opts{filter} })))
}

## Letterbox-fit into an exact $width x $height canvas, preserving aspect ratio
## and centering on a background fill. opts: color (default black), filter.
fn Office::img_fit ($handle, $width, $height, %opts) {
    Office::_decode("img_fit",
        office__img_fit(to_json({ handle => $handle, width => $width, height => $height, color => $opts{color}, filter => $opts{filter} })))
}

## Crop to a rectangle.
fn Office::img_crop ($handle, $x, $y, $width, $height) {
    Office::_decode("img_crop",
        office__img_crop(to_json({ handle => $handle, x => $x, y => $y, width => $width, height => $height })))
}

## Rotate by degrees (90/180/270 are exact; other angles fill transparent).
fn Office::img_rotate ($handle, $degrees) {
    Office::_decode("img_rotate",
        office__img_rotate(to_json({ handle => $handle, degrees => $degrees })))
}

## Flip horizontally ("h") or vertically ("v").
fn Office::img_flip ($handle, $dir) {
    Office::_decode("img_flip", office__img_flip(to_json({ handle => $handle, dir => $dir })))
}

## Convert pixel mode: "L" (grayscale), "LA", "RGB", "RGBA".
fn Office::img_convert ($handle, $mode) {
    Office::_decode("img_convert", office__img_convert(to_json({ handle => $handle, mode => $mode })))
}

## Paste image $src onto $handle at ($x, $y) with alpha compositing.
fn Office::img_paste ($handle, $src, $x, $y) {
    Office::_decode("img_paste",
        office__img_paste(to_json({ handle => $handle, src => $src, x => $x, y => $y })))
}

## Read a pixel; returns { r, g, b, a }.
fn Office::img_get_pixel ($handle, $x, $y) {
    Office::_decode("img_get_pixel",
        office__img_get_pixel(to_json({ handle => $handle, x => $x, y => $y })))
}

## Set a pixel to $color.
fn Office::img_put_pixel ($handle, $x, $y, $color) {
    Office::_decode("img_put_pixel",
        office__img_put_pixel(to_json({ handle => $handle, x => $x, y => $y, color => $color })))
}

## Draw a rectangle. opts: fill => 1 (default) or 0 for outline.
fn Office::img_draw_rect ($handle, $x, $y, $width, $height, $color, %opts) {
    Office::_decode("img_draw_rect",
        office__img_draw_rect(to_json({ handle => $handle, x => $x, y => $y, width => $width, height => $height, color => $color, fill => $opts{fill} })))
}

## Draw a line segment from ($x0,$y0) to ($x1,$y1).
fn Office::img_draw_line ($handle, $x0, $y0, $x1, $y1, $color) {
    Office::_decode("img_draw_line",
        office__img_draw_line(to_json({ handle => $handle, x0 => $x0, y0 => $y0, x1 => $x1, y1 => $y1, color => $color })))
}

## Draw a circle centered at ($x,$y). opts: fill => 1 (default) or 0.
fn Office::img_draw_circle ($handle, $x, $y, $radius, $color, %opts) {
    Office::_decode("img_draw_circle",
        office__img_draw_circle(to_json({ handle => $handle, x => $x, y => $y, radius => $radius, color => $color, fill => $opts{fill} })))
}

## Draw text. opts: size (default 16), font => "/path.ttf" (default: vendored DejaVu Sans).
fn Office::img_draw_text ($handle, $x, $y, $text, $color, %opts) {
    Office::_decode("img_draw_text",
        office__img_draw_text(to_json({ handle => $handle, x => $x, y => $y, text => $text, color => $color, size => $opts{size}, font => $opts{font} })))
}

## Release an image handle.
fn Office::img_close ($handle) {
    Office::_decode("img_close", office__img_close(to_json({ handle => $handle })))
}

# ── image filters (in place on the handle) ──────────────────────────

## Gaussian blur. opts: sigma (default 2).
fn Office::img_blur ($handle, %opts) {
    Office::_decode("img_blur", office__img_blur(to_json({ handle => $handle, sigma => $opts{sigma} })))
}

## Unsharp-mask sharpen. opts: sigma (default 2), threshold (default 2).
fn Office::img_sharpen ($handle, %opts) {
    Office::_decode("img_sharpen",
        office__img_sharpen(to_json({ handle => $handle, sigma => $opts{sigma}, threshold => $opts{threshold} })))
}

## Brighten by $value (negative darkens).
fn Office::img_brighten ($handle, $value) {
    Office::_decode("img_brighten", office__img_brighten(to_json({ handle => $handle, value => $value })))
}

## Adjust contrast by $value (negative reduces).
fn Office::img_contrast ($handle, $value) {
    Office::_decode("img_contrast", office__img_contrast(to_json({ handle => $handle, value => $value })))
}

## Rotate hue by $degrees.
fn Office::img_huerotate ($handle, $degrees) {
    Office::_decode("img_huerotate", office__img_huerotate(to_json({ handle => $handle, degrees => $degrees })))
}

## Invert colors.
fn Office::img_invert ($handle) {
    Office::_decode("img_invert", office__img_invert(to_json({ handle => $handle })))
}

## Convert to grayscale (luma).
fn Office::img_grayscale ($handle) {
    Office::_decode("img_grayscale", office__img_grayscale(to_json({ handle => $handle })))
}

## Gamma correction ($gamma > 1 brightens midtones, < 1 darkens).
fn Office::img_gamma ($handle, $gamma) {
    Office::_decode("img_gamma", office__img_gamma(to_json({ handle => $handle, gamma => $gamma })))
}

## Binarize at luma $level (0-255), default 128.
fn Office::img_threshold ($handle, %opts) {
    Office::_decode("img_threshold", office__img_threshold(to_json({ handle => $handle, level => $opts{level} })))
}

## Reduce each channel to $levels steps (2-256).
fn Office::img_posterize ($handle, $levels) {
    Office::_decode("img_posterize", office__img_posterize(to_json({ handle => $handle, levels => $levels })))
}

## Apply a sepia tone.
fn Office::img_sepia ($handle) {
    Office::_decode("img_sepia", office__img_sepia(to_json({ handle => $handle })))
}

## Multiply colors by $color ("#rrggbb" or [r,g,b]).
fn Office::img_tint ($handle, $color) {
    Office::_decode("img_tint", office__img_tint(to_json({ handle => $handle, color => $color })))
}

# ── extended processing (PIL-complete surface) ──────────────────────

## Auto-contrast: stretch each channel to full range. opts: cutoff (percent
## of each histogram tail to clip, default 0).
fn Office::img_autocontrast ($handle, %opts) {
    Office::_decode("img_autocontrast", office__img_autocontrast(to_json({ handle => $handle, cutoff => $opts{cutoff} })))
}

## Per-channel histogram equalization.
fn Office::img_equalize ($handle) {
    Office::_decode("img_equalize", office__img_equalize(to_json({ handle => $handle })))
}

## Solarize: invert channel values at/above $threshold (default 128).
fn Office::img_solarize ($handle, %opts) {
    Office::_decode("img_solarize", office__img_solarize(to_json({ handle => $handle, threshold => $opts{threshold} })))
}

## Colorize grayscale to a gradient between $black (luma 0) and $white (255).
fn Office::img_colorize ($handle, $black, $white) {
    Office::_decode("img_colorize", office__img_colorize(to_json({ handle => $handle, black => $black, white => $white })))
}

## Emboss via a fixed 3x3 kernel.
fn Office::img_emboss ($handle) {
    Office::_decode("img_emboss", office__img_emboss(to_json({ handle => $handle })))
}

## Apply an arbitrary 3x3 convolution. $kernel is 9 numbers (row-major).
## opts: divisor (default kernel sum), offset (default 0).
fn Office::img_convolve ($handle, $kernel, %opts) {
    Office::_decode("img_convolve",
        office__img_convolve(to_json({ handle => $handle, kernel => $kernel, divisor => $opts{divisor}, offset => $opts{offset} })))
}

## Canny edge detection -> white edges on black (returns new geometry/mode).
## opts: low (default 30), high (default 100).
fn Office::img_edges ($handle, %opts) {
    Office::_decode("img_edges", office__img_edges(to_json({ handle => $handle, low => $opts{low}, high => $opts{high} })))
}

## Separable box blur. opts: radius (default 2).
fn Office::img_box_blur ($handle, %opts) {
    Office::_decode("img_box_blur", office__img_box_blur(to_json({ handle => $handle, radius => $opts{radius} })))
}

## Median (despeckle) filter. opts: radius (default 1).
fn Office::img_median ($handle, %opts) {
    Office::_decode("img_median", office__img_median(to_json({ handle => $handle, radius => $opts{radius} })))
}

## Pixelate / mosaic. opts: block (default 8).
fn Office::img_pixelate ($handle, %opts) {
    Office::_decode("img_pixelate", office__img_pixelate(to_json({ handle => $handle, block => $opts{block} })))
}

## Radial vignette. opts: strength 0..1 (default 0.6).
fn Office::img_vignette ($handle, %opts) {
    Office::_decode("img_vignette", office__img_vignette(to_json({ handle => $handle, strength => $opts{strength} })))
}

## Scale alpha by $factor 0..1.
fn Office::img_opacity ($handle, $factor) {
    Office::_decode("img_opacity", office__img_opacity(to_json({ handle => $handle, factor => $factor })))
}

## Set a constant alpha for every pixel (0..255).
fn Office::img_putalpha ($handle, $alpha) {
    Office::_decode("img_putalpha", office__img_putalpha(to_json({ handle => $handle, alpha => $alpha })))
}

## Cross-fade base toward $src by $alpha 0..1 ($src resized to base size).
fn Office::img_blend ($handle, $src, $alpha) {
    Office::_decode("img_blend", office__img_blend(to_json({ handle => $handle, src => $src, alpha => $alpha })))
}

## Blend two handles with a $mode: multiply/screen/overlay/darken/lighten/
## difference/add/subtract.
fn Office::img_blend_mode ($handle, $src, $mode) {
    Office::_decode("img_blend_mode", office__img_blend_mode(to_json({ handle => $handle, src => $src, mode => $mode })))
}

## Composite $src over base through grayscale $mask (white=src, black=base).
fn Office::img_composite ($handle, $src, $mask) {
    Office::_decode("img_composite", office__img_composite(to_json({ handle => $handle, src => $src, mask => $mask })))
}

## Grow the canvas with a solid border. opts: size (default 10), color.
fn Office::img_border ($handle, %opts) {
    Office::_decode("img_border", office__img_border(to_json({ handle => $handle, size => $opts{size}, color => $opts{color} })))
}

## Autocrop a uniform border matching the top-left pixel. opts: tolerance
## (default 0).
fn Office::img_trim ($handle, %opts) {
    Office::_decode("img_trim", office__img_trim(to_json({ handle => $handle, tolerance => $opts{tolerance} })))
}

## Transpose across the main diagonal (swaps W/H).
fn Office::img_transpose ($handle) {
    Office::_decode("img_transpose", office__img_transpose(to_json({ handle => $handle })))
}

## Transverse across the anti-diagonal (swaps W/H).
fn Office::img_transverse ($handle) {
    Office::_decode("img_transverse", office__img_transverse(to_json({ handle => $handle })))
}

## Per-channel 256-bin histograms: { r, g, b, luma } -> arrayrefs of counts.
fn Office::img_histogram ($handle) {
    Office::_decode("img_histogram", office__img_histogram(to_json({ handle => $handle })))
}

## Min/max of each channel: { r=>[lo,hi], g, b, a }.
fn Office::img_extrema ($handle) {
    Office::_decode("img_extrema", office__img_extrema(to_json({ handle => $handle })))
}

## Add noise. opts: kind => "gaussian"|"salt_pepper", amount (gaussian stddev
## ~20, or s&p rate 0..1 ~0.05), seed (default 1).
fn Office::img_noise ($handle, %opts) {
    Office::_decode("img_noise",
        office__img_noise(to_json({ handle => $handle, kind => $opts{kind}, amount => $opts{amount}, seed => $opts{seed} })))
}

## Tile a semi-transparent diagonal watermark. opts: color, size (28),
## opacity 0..1 (0.25), gap (220), font.
fn Office::img_watermark ($handle, $text, %opts) {
    Office::_decode("img_watermark",
        office__img_watermark(to_json({ handle => $handle, text => $text, color => $opts{color}, size => $opts{size}, opacity => $opts{opacity}, gap => $opts{gap}, font => $opts{font} })))
}

## Split into channel images. Returns { handles => { r, g, b, a } }, each a
## grayscale (L) image; close them when done.
fn Office::img_split ($handle) {
    Office::_decode("img_split", office__img_split(to_json({ handle => $handle })))
}

## Merge grayscale channel handles into one image. $a is optional (opaque if
## omitted). Returns a new image handle.
fn Office::img_merge ($r, $g, $b, %opts) {
    Office::_decode("img_merge", office__img_merge(to_json({ r => $r, g => $g, b => $b, a => $opts{a} })))
}

## Morphological dilate. opts: iterations (default 1).
fn Office::img_dilate ($handle, %opts) {
    Office::_decode("img_dilate", office__img_dilate(to_json({ handle => $handle, iterations => $opts{iterations} })))
}

## Morphological erode. opts: iterations (default 1).
fn Office::img_erode ($handle, %opts) {
    Office::_decode("img_erode", office__img_erode(to_json({ handle => $handle, iterations => $opts{iterations} })))
}

# ── animation, advanced drawing, transforms, byte I/O ───────────────

## Open an animated image (gif/webp). Returns { count, frames => [{handle,
## width, height, delay_ms}] }; close each frame handle when done. A static
## image comes back as a single frame.
fn Office::img_open_frames ($path) {
    Office::_decode("img_open_frames", office__img_open_frames(to_json({ path => $path })))
}

## Write an animated GIF from image handles (resized to the first frame).
## opts: delay (ms, default 100), delays => [ms,...] per frame, repeat =>
## "infinite" (default) or an integer loop count.
fn Office::img_save_animated ($path, $handles, %opts) {
    Office::_decode("img_save_animated",
        office__img_save_animated(to_json({ path => $path, handles => $handles, delay => $opts{delay}, delays => $opts{delays}, repeat => $opts{repeat} })))
}

## Combine image handles into a grid montage. opts: cols (default
## ceil(sqrt(n))), gap (default 4), bg. Returns a new image handle.
fn Office::img_montage ($handles, %opts) {
    Office::_decode("img_montage",
        office__img_montage(to_json({ handles => $handles, cols => $opts{cols}, gap => $opts{gap}, bg => $opts{bg} })))
}

## Fill the image with a gradient. opts: kind => "linear"|"radial", from, to,
## angle (deg, linear; 0 = left->right).
fn Office::img_gradient ($handle, %opts) {
    Office::_decode("img_gradient",
        office__img_gradient(to_json({ handle => $handle, kind => $opts{kind}, from => $opts{from}, to => $opts{to}, angle => $opts{angle} })))
}

## Draw an ellipse centered at ($x,$y) with radii ($rx,$ry). opts: fill => 1
## (default) or 0.
fn Office::img_draw_ellipse ($handle, $x, $y, $rx, $ry, $color, %opts) {
    Office::_decode("img_draw_ellipse",
        office__img_draw_ellipse(to_json({ handle => $handle, x => $x, y => $y, rx => $rx, ry => $ry, color => $color, fill => $opts{fill} })))
}

## Draw a filled polygon from $points ([[x,y],...]).
fn Office::img_draw_polygon ($handle, $points, $color) {
    Office::_decode("img_draw_polygon",
        office__img_draw_polygon(to_json({ handle => $handle, points => $points, color => $color })))
}

## Draw multi-line text (splits on "\n"). opts: size (16), line_height, font.
fn Office::img_draw_text_multiline ($handle, $x, $y, $text, $color, %opts) {
    Office::_decode("img_draw_text_multiline",
        office__img_draw_text_multiline(to_json({ handle => $handle, x => $x, y => $y, text => $text, color => $color, size => $opts{size}, line_height => $opts{line_height}, font => $opts{font} })))
}

## Apply a 3x3 projective transform ($matrix = 9 row-major numbers): affine
## or perspective. Out-of-bounds fills transparent.
fn Office::img_warp ($handle, $matrix) {
    Office::_decode("img_warp", office__img_warp(to_json({ handle => $handle, matrix => $matrix })))
}

## Encode an image handle to a base64 string. opts: format (default "png").
## Returns { base64, format, bytes }.
fn Office::img_to_base64 ($handle, %opts) {
    Office::_decode("img_to_base64", office__img_to_base64(to_json({ handle => $handle, format => $opts{format} })))
}

## Decode a base64 string into a new image handle. Returns image info.
fn Office::img_from_base64 ($base64) {
    Office::_decode("img_from_base64", office__img_from_base64(to_json({ base64 => $base64 })))
}

## Encode an image file as a data: URI for inline HTML/CSS embedding (MIME from
## extension). Returns { data_uri, mime, bytes }.
fn Office::img_data_uri ($path) {
    Office::_decode("img_data_uri", office__img_data_uri(to_json({ path => $path })))
}

## Open, resize, and save an image file in one call (output format by extension,
## so it also transcodes). opts: max => fit within max x max (aspect preserved),
## or width + height => exact. Returns { ok, path, width, height }.
fn Office::img_resize_file ($input, $output, %opts) {
    Office::_decode("img_resize_file",
        office__img_resize_file(to_json({ input => $input, output => $output, max => $opts{max}, width => $opts{width}, height => $opts{height} })))
}

## Build a contact sheet (thumbnail grid) image from a list of image files.
## $images is an arrayref of paths. opts: thumb => max px per cell (default 128),
## cols, gap, bg. Returns { ok, path, count, width, height }.
fn Office::contact_sheet ($images, $output, %opts) {
    Office::_decode("contact_sheet",
        office__contact_sheet(to_json({ images => $images, output => $output, thumb => $opts{thumb}, cols => $opts{cols}, gap => $opts{gap}, bg => $opts{bg} })))
}

# ── shapes, fills, masks, color analysis ────────────────────────────

## Draw a rounded rectangle. opts: radius (8), fill => 1 (default) or 0
## (outline, stroke px wide).
fn Office::img_draw_rounded_rect ($handle, $x, $y, $width, $height, $color, %opts) {
    Office::_decode("img_draw_rounded_rect",
        office__img_draw_rounded_rect(to_json({ handle => $handle, x => $x, y => $y, width => $width, height => $height, radius => $opts{radius}, color => $color, fill => $opts{fill}, stroke => $opts{stroke} })))
}

## Draw an open polyline through $points ([[x,y],...]).
fn Office::img_draw_polyline ($handle, $points, $color) {
    Office::_decode("img_draw_polyline",
        office__img_draw_polyline(to_json({ handle => $handle, points => $points, color => $color })))
}

## Draw an arc from $start to $end degrees, radius $r at ($x,$y). opts:
## fill => 1 draws a filled wedge.
fn Office::img_draw_arc ($handle, $x, $y, $r, $start, $end, $color, %opts) {
    Office::_decode("img_draw_arc",
        office__img_draw_arc(to_json({ handle => $handle, x => $x, y => $y, radius => $r, start => $start, end => $end, color => $color, fill => $opts{fill} })))
}

## Bucket flood fill from seed ($x,$y). opts: tolerance (default 0).
fn Office::img_flood_fill ($handle, $x, $y, $color, %opts) {
    Office::_decode("img_flood_fill",
        office__img_flood_fill(to_json({ handle => $handle, x => $x, y => $y, color => $color, tolerance => $opts{tolerance} })))
}

## Replace pixels near $from with $to. opts: tolerance (default 16).
fn Office::img_replace_color ($handle, $from, $to, %opts) {
    Office::_decode("img_replace_color",
        office__img_replace_color(to_json({ handle => $handle, from => $from, to => $to, tolerance => $opts{tolerance} })))
}

## Permute channels by an $order string over r/g/b/a (e.g. "bgr", "grba").
fn Office::img_swap_channels ($handle, $order) {
    Office::_decode("img_swap_channels", office__img_swap_channels(to_json({ handle => $handle, order => $order })))
}

## Top-K dominant colors. opts: count (default 5). Returns { colors =>
## [{r,g,b,hex,count}] }.
fn Office::img_dominant_colors ($handle, %opts) {
    Office::_decode("img_dominant_colors", office__img_dominant_colors(to_json({ handle => $handle, count => $opts{count} })))
}

## Compare two handles ($other resized to base). Returns { mse, rmse,
## max_diff, identical }; opts: diff => 1 to also return a diff_handle.
fn Office::img_compare ($handle, $other, %opts) {
    Office::_decode("img_compare", office__img_compare(to_json({ handle => $handle, other => $other, diff => $opts{diff} })))
}

## Measure rendered text. opts: size (16), font. Returns { width, height }.
fn Office::img_text_size ($text, %opts) {
    Office::_decode("img_text_size", office__img_text_size(to_json({ text => $text, size => $opts{size}, font => $opts{font} })))
}

## Add a caption bar with centered text above/below an image. opts: position
## (bottom/top), height, size, color, background, font. Returns { ok, path, width, height }.
fn Office::img_caption ($input, $output, $text, %opts) {
    Office::_decode("img_caption",
        office__img_caption(to_json({ input => $input, output => $output, text => $text, position => $opts{position}, height => $opts{height}, size => $opts{size}, color => $opts{color}, background => $opts{background}, font => $opts{font} })))
}

## Mask to the inscribed circle (transparent outside).
fn Office::img_crop_circle ($handle) {
    Office::_decode("img_crop_circle", office__img_crop_circle(to_json({ handle => $handle })))
}

## Round the image corners (transparent outside). opts: radius (default 16).
fn Office::img_round_corners ($handle, %opts) {
    Office::_decode("img_round_corners", office__img_round_corners(to_json({ handle => $handle, radius => $opts{radius} })))
}

## Add a soft drop shadow (grows the canvas). opts: dx (6), dy (6), blur
## sigma (4), color (black), opacity 0..1 (0.5).
fn Office::img_drop_shadow ($handle, %opts) {
    Office::_decode("img_drop_shadow",
        office__img_drop_shadow(to_json({ handle => $handle, dx => $opts{dx}, dy => $opts{dy}, blur => $opts{blur}, color => $opts{color}, opacity => $opts{opacity} })))
}

# ── color science + distortions ─────────────────────────────────────

## Per-channel levels. opts: in_black (0), in_white (255), gamma (1),
## out_black (0), out_white (255).
fn Office::img_levels ($handle, %opts) {
    Office::_decode("img_levels",
        office__img_levels(to_json({ handle => $handle, in_black => $opts{in_black}, in_white => $opts{in_white}, gamma => $opts{gamma}, out_black => $opts{out_black}, out_white => $opts{out_white} })))
}

## Tone curve from control $points ([[x,y],...], 0..255), applied to RGB.
fn Office::img_curves ($handle, $points) {
    Office::_decode("img_curves", office__img_curves(to_json({ handle => $handle, points => $points })))
}

## Adjust HSL. opts: hue (deg shift), saturation (multiplier), lightness
## (multiplier).
fn Office::img_hsl ($handle, %opts) {
    Office::_decode("img_hsl",
        office__img_hsl(to_json({ handle => $handle, hue => $opts{hue}, saturation => $opts{saturation}, lightness => $opts{lightness} })))
}

## White-balance shift. $amount -100..100 (positive = warmer).
fn Office::img_temperature ($handle, $amount) {
    Office::_decode("img_temperature", office__img_temperature(to_json({ handle => $handle, amount => $amount })))
}

## Channel mixer: 9-number row-major matrix mixing source RGB into output RGB.
fn Office::img_channel_mixer ($handle, $matrix) {
    Office::_decode("img_channel_mixer", office__img_channel_mixer(to_json({ handle => $handle, matrix => $matrix })))
}

## Swirl distortion around center. opts: strength (radians, 3), radius (px).
fn Office::img_swirl ($handle, %opts) {
    Office::_decode("img_swirl", office__img_swirl(to_json({ handle => $handle, strength => $opts{strength}, radius => $opts{radius} })))
}

## Sinusoidal wave displacement. opts: amplitude (10), wavelength (40),
## axis ("x"|"y").
fn Office::img_wave ($handle, %opts) {
    Office::_decode("img_wave", office__img_wave(to_json({ handle => $handle, amplitude => $opts{amplitude}, wavelength => $opts{wavelength}, axis => $opts{axis} })))
}

## Fisheye (barrel) distortion. opts: strength 0..1 (0.5).
fn Office::img_fisheye ($handle, %opts) {
    Office::_decode("img_fisheye", office__img_fisheye(to_json({ handle => $handle, strength => $opts{strength} })))
}

## Kaleidoscope mirror. opts: segments (6).
fn Office::img_kaleidoscope ($handle, %opts) {
    Office::_decode("img_kaleidoscope", office__img_kaleidoscope(to_json({ handle => $handle, segments => $opts{segments} })))
}

## Split into a grid of sub-images. opts: cols (1), rows (1). Returns
## { handles => [...], cols, rows, cell_width, cell_height }.
fn Office::img_spritesheet ($handle, %opts) {
    Office::_decode("img_spritesheet", office__img_spritesheet(to_json({ handle => $handle, cols => $opts{cols}, rows => $opts{rows} })))
}

## Content-aware width reduction (seam carving) to $width px.
fn Office::img_seam_carve ($handle, $width) {
    Office::_decode("img_seam_carve", office__img_seam_carve(to_json({ handle => $handle, width => $width })))
}

## Floyd-Steinberg dither to $levels steps per channel. opts: levels (2).
fn Office::img_dither ($handle, %opts) {
    Office::_decode("img_dither", office__img_dither(to_json({ handle => $handle, levels => $opts{levels} })))
}

## Median-cut quantize to a palette and remap. opts: colors (16). Returns
## { colors => [{r,g,b,hex}] }.
fn Office::img_quantize ($handle, %opts) {
    Office::_decode("img_quantize", office__img_quantize(to_json({ handle => $handle, colors => $opts{colors} })))
}

## Write a multi-resolution .ico favicon. opts: sizes => [16,32,48].
fn Office::img_favicon ($handle, $path, %opts) {
    Office::_decode("img_favicon", office__img_favicon(to_json({ handle => $handle, path => $path, sizes => $opts{sizes} })))
}

# ── charts (data -> image handle -> any format) ─────────────────────
#
# Render a chart to an image handle, then img_save it in whatever format
# you want (png/jpeg/gif/bmp/webp/tiff) or process it further. Fully
# self-contained — no plotters, no system fonts, no external binaries.

## Render a chart to a raster image handle. $type is one of:
##   bar | column | stacked | line | area | stacked_area | step | combo |
##   scatter | bubble | pie | donut | radar | histogram | sankey | waterfall |
##   ohlc | candlestick | boxplot | funnel | gauge | heatmap | treemap |
##   polar | bullet | pareto | lollipop | dot | gantt | sunburst |
##   range | range_column | percent_stacked | streamgraph | waffle | slope |
##   marimekko | radial_bar | calendar | parallel | hexbin
## $series: arrayref of { name, data => [n, ...], color?, kind? }.
##   bullet series => { name, value, target, ranges => [r1,r2,...] };
##   gantt series => { name, start, end, color? };
##   range/range_column => data => [[low,high],...];
##   sunburst => rings => [[..],[..]] innermost first (no series needed);
##   calendar => values => [v,...] laid out 7 rows x N cols (no series needed);
##   parallel => each series is one row of per-dimension values (cats = axes);
##   hexbin => scatter data => [[x,y],...] binned into hex cells;
##   scatter accepts trendline => 1 to overlay a least-squares line.
## Cross-cutting opts: markers => 1 (line family), reference_lines =>
##   [{ y, color? }] (horizontal threshold lines), smooth => 1 (spline lines),
##   palette => ["#..."] (custom color cycle), background => "#..." (canvas),
##   log_y => 1 (logarithmic Y when all-positive), per-series errors => [e,...]
##   (error-bar whiskers), annotations => [{ x (data index), y, text, color? }].
##   scatter data => [[x, y], ...]; bubble => [[x, y, size], ...];
##   ohlc/candlestick => [[open, high, low, close], ...];
##   boxplot data => raw numbers (min/q1/median/q3/max computed);
##   combo series can set kind => "line" to overlay a line on the bars;
##   pie/funnel use the first series' data as slices/bands.
## opts: title, width (800), height (600), categories => [labels],
##   legend => 0 to suppress, labels => 1 for data labels, x_label, y_label,
##   bins (histogram), value+max (gauge), matrix => [[..],..] (heatmap),
##   nodes+links (sankey). Returns { handle, width, height, type } — pass the
## handle to Office::img_save (any raster format) or any img_* op.
fn Office::chart_render ($type, $series, %opts) {
    var %r = %opts
    $r{type} = $type
    $r{series} = $series
    Office::_decode("chart_render", office__chart_render(to_json(\%r)))
}

## Render a chart straight from a spreadsheet's columns and save it. $path is the
## spreadsheet, $output the chart file (.svg/.pdf/.png/... sets the format).
## opts: type (bar/line/...), sheet, header => 0, categories => column for x
## labels, series => arrayref of value columns (default: all numeric columns),
## plus chart options (title, width, height, smooth, ...). Returns the chart_save
## result.
fn Office::chart_from_sheet ($path, $output, %opts) {
    var %r = %opts
    $r{path} = $path
    $r{output} = $output
    Office::_decode("chart_from_sheet", office__chart_from_sheet(to_json(\%r)))
}

## Render a chart to a vector SVG string (returns the markup), or write it
## to %opts{path} if given. Same spec keys as chart_render.
fn Office::chart_svg ($type, $series, %opts) {
    var %r = %opts
    $r{type} = $type
    $r{series} = $series
    val $o = Office::_decode("chart_svg", office__chart_svg(to_json(\%r)))
    exists $o->{svg} ? $o->{svg} : $o
}

## Render many chart specs and tile them into one dashboard image. $charts is
## an arrayref of full chart specs (each as for chart_render). opts: cols,
## cell_width (400), cell_height (300), gap (10), background, path (save the
## grid straight to any raster extension or .pdf). Returns { handle, width,
## height, charts } — or { ok, path, charts } when path is given.
fn Office::chart_grid ($charts, %opts) {
    var %r = %opts
    $r{charts} = $charts
    Office::_decode("chart_grid", office__chart_grid(to_json(\%r)))
}

## Render a chart straight to a file, format chosen by $path extension:
## .svg (vector), .pdf (chart embedded in a PDF), or any raster extension
## (.png/.jpg/.tif/.bmp/.webp/.gif). Sankey takes nodes/links instead of
## series. Spec opts: title, width, height, categories, bins, nodes, links.
fn Office::chart_save ($type, $path, %opts) {
    var %r = %opts
    $r{type} = $type
    $r{path} = $path
    Office::_decode("chart_save", office__chart_save(to_json(\%r)))
}

## Generate a QR code -> image handle. opts: ec (L/M/Q/H, default M),
## scale (px/module, 6), quiet (modules, 4), fg, bg. Returns
## { handle, width, height, modules }. Save/embed via the image surface.
fn Office::barcode_qr ($data, %opts) {
    var %r = %opts
    $r{data} = $data
    Office::_decode("barcode_qr", office__barcode_qr(to_json(\%r)))
}

## Generate a 1D barcode -> image handle. $symbology is one of code128,
## code39, code93, code11, codabar, ean13, ean8, upca, itf, std2of5.
## opts: scale (px/bar, 2), height (px, 80), quiet (px), fg, bg, set
## (Code128 A/B/C). Returns { handle, width, height, symbology, bars }.
fn Office::barcode_1d ($symbology, $data, %opts) {
    var %r = %opts
    $r{symbology} = $symbology
    $r{data} = $data
    Office::_decode("barcode_1d", office__barcode_1d(to_json(\%r)))
}

## Generate a barcode straight to an image file (format by extension). $data is
## the payload. opts: kind => "qr" (default) | "1d", plus generator options
## (ec/scale/quiet for qr; symbology/scale/height for 1d; fg/bg). Returns
## { ok, path, kind, width, height }.
fn Office::barcode_save ($data, $output, %opts) {
    var %r = %opts
    $r{data} = $data
    $r{output} = $output
    Office::_decode("barcode_save", office__barcode_save(to_json(\%r)))
}
