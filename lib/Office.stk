}

## Import a JSON file (array of objects) into a spreadsheet. opts: fields =>
## explicit column order, sheet_name, format => override. Returns
## { ok, path, rows, fields }.
fn Office::json_to_sheet ($input, $output, %opts) {
    Office::_decode("json_to_sheet",
        office__json_to_sheet(to_json({ input => $input, output => $output, fields => $opts{fields}, sheet_name => $opts{sheet_name}, format => $opts{format} })))
}

## Sort a sheet's data rows by $by (column name or 0-based index), preserving
